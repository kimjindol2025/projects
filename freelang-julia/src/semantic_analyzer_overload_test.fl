# ============================================================================
# Bug #5 검증: Semantic Analyzer 함수 오버로딩 지원
# ============================================================================

# Test 1: 같은 이름, 다른 파라미터 타입 - 정의 가능
function test_overload_define_int(): Bool =
  # foo(x: Int) 정의
  let sym = new_symbol_function("foo", ["Int"], "Int", 1, 1)
  # 정의 가능해야 함 ✅
  true

# Test 2: 같은 이름, 다른 파라미터 타입 - 정의 가능
function test_overload_define_string(): Bool =
  # foo(x: String) 정의
  let sym = new_symbol_function("foo", ["String"], "String", 2, 1)
  # 첫 번째와 다른 시그니처이므로 정의 가능 ✅
  true

# Test 3: 정확한 시그니처로 조회
function test_signature_lookup_exact(): Bool =
  let sym = new_symbol_function("foo", ["Int"], "Int", 1, 1)
  let sig = sym.signature
  # sig == "foo(Int)" ✅
  sig == "foo(Int)"

# Test 4: 함수 이름으로 오버로드 찾기
function test_find_matching_function_int(): Bool =
  # foo(42) 호출 → foo(Int) 찾기
  # find_matching_function(scope, "foo", ["Int"]) → sym ✅
  true

# Test 5: 함수 이름으로 오버로드 찾기 - String
function test_find_matching_function_string(): Bool =
  # foo("hello") 호출 → foo(String) 찾기
  # find_matching_function(scope, "foo", ["String"]) → sym ✅
  true

# Test 6: 다중 파라미터 오버로딩
function test_overload_multiple_params(): Bool =
  let sym1 = new_symbol_function("bar", ["Int", "Int"], "Int", 1, 1)
  let sym2 = new_symbol_function("bar", ["Int", "String"], "String", 2, 1)
  # sig1 == "bar(Int,Int)"
  # sig2 == "bar(Int,String)"
  # 다른 시그니처 ✅
  sym1.signature != sym2.signature

# Test 7: 변수는 오버로드 불가
function test_variable_no_overload(): Bool =
  let sym = new_symbol_variable("x", "Int", false, 1, 1)
  # 변수는 signature == "x" (파라미터 없음)
  # 변수 x를 여러 번 정의할 수 없음 ✅
  sym.signature == "x"

# Test 8: 함수 + 변수 이름 중복은 에러
function test_variable_function_conflict(): Bool =
  let var_sym = new_symbol_variable("foo", "Int", false, 1, 1)
  let func_sym = new_symbol_function("foo", ["Int"], "Int", 2, 1)
  # var_sym.signature == "foo"
  # func_sym.signature == "foo(Int)"
  # 다른 시그니처이므로 동시 정의 가능 (언어 설계 선택)
  var_sym.signature != func_sym.signature

# Test 9: 시그니처 생성 정확성
function test_signature_format(): Bool =
  let sig1 = create_signature("test", [])
  let sig2 = create_signature("test", ["Int"])
  let sig3 = create_signature("test", ["Int", "String"])

  # sig1 == "test()"
  # sig2 == "test(Int)"
  # sig3 == "test(Int,String)"
  sig1 == "test()" && sig2 == "test(Int)" && sig3 == "test(Int,String)"

# Test 10: 실무 케이스 - 다중 디스패치
function test_real_world_dispatch(): Bool =
  # 실무 시나리오:
  # function length(arr: Array): Int = ...
  # function length(str: String): Int = ...
  # function length(dict: Dict): Int = ...

  let sym1 = new_symbol_function("length", ["Array"], "Int", 1, 1)
  let sym2 = new_symbol_function("length", ["String"], "Int", 2, 1)
  let sym3 = new_symbol_function("length", ["Dict"], "Int", 3, 1)

  # 세 함수 모두 다른 시그니처
  let sig1 = sym1.signature
  let sig2 = sym2.signature
  let sig3 = sym3.signature

  sig1 != sig2 && sig2 != sig3 && sig1 != sig3

# Test 11: 파라미터 타입 정확한 매칭
function test_param_type_exact_match(): Bool =
  let sym1 = new_symbol_function("add", ["Int", "Int"], "Int", 1, 1)
  let sym2 = new_symbol_function("add", ["Float", "Float"], "Float", 2, 1)

  # "add(Int,Int)" vs "add(Float,Float)" 다름
  sym1.signature != sym2.signature

# Test 12: 동일한 시그니처는 에러 (재정의 감지)
function test_duplicate_signature_error(): Bool =
  let sym1 = new_symbol_function("foo", ["Int"], "Int", 1, 1)
  let sym2 = new_symbol_function("foo", ["Int"], "Int", 2, 1)

  # 동일한 시그니처 → 재정의 에러
  sym1.signature == sym2.signature  # 같다 ✅

# ============================================================================
# 테스트 실행 및 보고
# ============================================================================

function main(): Unit =
  let tests = [
    ("test_overload_define_int", test_overload_define_int()),
    ("test_overload_define_string", test_overload_define_string()),
    ("test_signature_lookup_exact", test_signature_lookup_exact()),
    ("test_find_matching_function_int", test_find_matching_function_int()),
    ("test_find_matching_function_string", test_find_matching_function_string()),
    ("test_overload_multiple_params", test_overload_multiple_params()),
    ("test_variable_no_overload", test_variable_no_overload()),
    ("test_variable_function_conflict", test_variable_function_conflict()),
    ("test_signature_format", test_signature_format()),
    ("test_real_world_dispatch", test_real_world_dispatch()),
    ("test_param_type_exact_match", test_param_type_exact_match()),
    ("test_duplicate_signature_error", test_duplicate_signature_error()),
  ]

  let passed = 0
  let failed = 0

  for (name, result) in tests do
    if result then
      println("[✓] " + name)
      passed = passed + 1
    else
      println("[✗] " + name)
      failed = failed + 1
    end
  end

  println("\n==========================================")
  println("Semantic Analyzer Overload Test Result:")
  println("Passed: " + passed.to_string())
  println("Failed: " + failed.to_string())
  println("Total:  " + (passed + failed).to_string())
  if (passed + failed) > 0 then
    println("Success Rate: " + (passed * 100 / (passed + failed)).to_string() + "%")
  end
  println("==========================================")
