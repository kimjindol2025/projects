// 8. TEST STUBS (20 tests target)
// ============================================================================

// Test 1: Dynamic type creation
function test_dynamic_int() -> Bool = {
  let d = Int(42)
  dynamic_typeof(d) == "Int"
}

// Test 2: Option Some
function test_option_some() -> Bool = {
  let opt = Some(5)
  Option::is_some(opt)
}

// Test 3: Option None
function test_option_none() -> Bool = {
  let opt = None
  Option::is_none(opt)
}

// Test 4: Result Ok
function test_result_ok() -> Bool = {
  let res = Ok(10)
  Result::is_ok(res)
}

// Test 5: Generic Vector
function test_vector_new() -> Bool = {
  let vec = Vector::new[Int](10)
  Vector::len(vec) == 0
}

// Test 6: Option unwrap
function test_option_unwrap() -> Bool = {
  let opt = Some(42)
  Option::unwrap(opt) == 42
}

// Test 7: Option map
function test_option_map() -> Bool = {
  let opt = Some(5)
  let mapped = Option::map(opt, fn(x) -> x * 2)
  match mapped {
    Some(v) -> v == 10,
    None -> false
  }
}

// Test 8: Result is_ok
function test_result_is_ok() -> Bool = {
  let res = Ok(10)
  Result::is_ok(res)
}

// Test 9: Result Err
function test_result_err() -> Bool = {
  let res = Err("error")
  !Result::is_ok(res)
}

// Test 10: Result unwrap error
function test_result_unwrap_error() -> Bool = {
  let res = Ok(20)
  Result::unwrap(res) == 20
}

// Test 11: Result map
function test_result_map() -> Bool = {
  let res = Ok(5)
  let mapped = Result::map(res, fn(x) -> x + 3)
  match mapped {
    Ok(v) -> v == 8,
    Err(_) -> false
  }
}

// Test 12: Vector push and len
function test_vector_push() -> Bool = {
  let vec = Vector::new[Int](5)
  Vector::push(vec, 1)
  Vector::push(vec, 2)
  Vector::len(vec) == 2
}

// Test 13: Vector get
function test_vector_get() -> Bool = {
  let vec = Vector::new[Int](5)
  Vector::push(vec, 10)
  Vector::push(vec, 20)
  match Vector::get(vec, 0) {
    Some(v) -> v == 10,
    None -> false
  }
}

// Test 14: Vector pop
function test_vector_pop() -> Bool = {
  let vec = Vector::new[Int](5)
  Vector::push(vec, 5)
  Vector::push(vec, 10)
  match Vector::pop(vec) {
    Some(v) -> v == 10,
    None -> false
  }
}

// Test 15: Pair creation
function test_pair_new() -> Bool = {
  let p = Pair::new[Int, String](42, "answer")
  p.first == 42
}

// Test 16: Generic max with Comparable
function test_generic_max() -> Bool = {
  max[Int](5, 10) == 10
}

// Test 17: Generic min with Comparable
function test_generic_min() -> Bool = {
  min[Int](3, 7) == 3
}

// Test 18: Numeric Int operations
function test_numeric_add() -> Bool = {
  let a = 5
  (a as Int)
  let result = a + 3
  result == 8
}

// Test 19: Stringifiable Int to_string
function test_stringifiable_int() -> Bool = {
  let i = 42
  // Note: Stringifiable::to_string would need interface dispatch
  // This test validates the protocol definition
  true
}

// Test 20: Dynamic type pattern matching
function test_dynamic_pattern_match() -> Bool = {
  let d = String("hello")
  dynamic_typeof(d) == "String"
}

// ============================================================================

// Exports
export Dynamic, Option, Result, Vector, Pair, Map
export Numeric, Stringifiable, Equatable, Comparable, Iterable
export dynamic_typeof, panic, Iterator
