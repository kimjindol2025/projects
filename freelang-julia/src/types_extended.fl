// FreeLang Julia Integration: Extended Type System
// Phase A.2: Dynamic Type, Union, Type Parameters, Protocols
// Status: 🟢 Work in Progress (50% - Structure)
// Tests: 20/20 target

module types_extended

// ============================================================================
// 1. DYNAMIC TYPE (Any Type)
// ============================================================================

// Dynamic type represents any Julia value
type Dynamic =
  | Int(i64)
  | Float(f64)
  | String(String)
  | Bool(bool)
  | List(List[Dynamic])
  | Map(Map[String, Dynamic])
  | Record(String, Map[String, Dynamic])
  | Function(fn(Dynamic) -> Dynamic)
  | Nil

function dynamic_typeof(d: Dynamic) -> String = match d {
  Int(_) -> "Int",
  Float(_) -> "Float",
  String(_) -> "String",
  Bool(_) -> "Bool",
  List(_) -> "List",
  Map(_) -> "Map",
  Record(name, _) -> format("Record({})", name),
  Function(_) -> "Function",
  Nil -> "Nil"
}

// ============================================================================
// 2. UNION TYPES & OPTIONAL
// ============================================================================

// Option[T]: Nullable type (None | Some[T])
type Option[T] =
  | None
  | Some(T)

function Option::is_some[T](opt: Option[T]) -> Bool = match opt {
  Some(_) -> true,
  None -> false
}

function Option::is_none[T](opt: Option[T]) -> Bool = match opt {
  None -> true,
  Some(_) -> false
}

function Option::unwrap[T](opt: Option[T]) -> T = match opt {
  Some(v) -> v,
  None -> panic("Called unwrap on None")
}

function Option::map[T, U](opt: Option[T], f: fn(T) -> U) -> Option[U] = match opt {
  Some(v) -> Some(f(v)),
  None -> None
}

// Result[T, E]: Success or Error
type Result[T, E] =
  | Ok(T)
  | Err(E)

function Result::is_ok[T, E](res: Result[T, E]) -> Bool = match res {
  Ok(_) -> true,
  Err(_) -> false
}

function Result::unwrap[T, E](res: Result[T, E]) -> T = match res {
  Ok(v) -> v,
  Err(e) -> panic(format("Unwrap error: {}", e))
}

function Result::map[T, U, E](res: Result[T, E], f: fn(T) -> U) -> Result[U, E] = match res {
  Ok(v) -> Ok(f(v)),
  Err(e) -> Err(e)
}

// ============================================================================
// 3. TYPE PARAMETERS (GENERICS)
// ============================================================================

// Vector[T]: Generic array wrapper
record Vector[T] {
  data: [T],
  len: Int,
  capacity: Int
}

function Vector::new[T](capacity: Int) -> Vector[T] = {
  Vector {
    data: Array::new[T](capacity),
    len: 0,
    capacity: capacity
  }
}

function Vector::push[T](vec: mutable Vector[T], item: T) -> Unit = {
  if vec.len >= vec.capacity {
    // Resize logic (simplified)
    vec.capacity = vec.capacity * 2
  }
  vec.data[vec.len] = item
  vec.len = vec.len + 1
}

function Vector::pop[T](vec: mutable Vector[T]) -> Option[T] = {
  if vec.len > 0 {
    vec.len = vec.len - 1
    Some(vec.data[vec.len])
  } else {
    None
  }
}

function Vector::get[T](vec: Vector[T], index: Int) -> Option[T] = {
  if index >= 0 && index < vec.len {
    Some(vec.data[index])
  } else {
    None
  }
}

function Vector::len[T](vec: Vector[T]) -> Int = vec.len

// Pair[A, B]: Generic pair type
record Pair[A, B] {
  first: A,
  second: B
}

function Pair::new[A, B](a: A, b: B) -> Pair[A, B] = {
  Pair { first: a, second: b }
}

// Map[K, V]: Generic map (key-value store)
record Map[K, V] {
  entries: [(K, V)],
  size: Int
}

// ============================================================================
// 4. PROTOCOLS (INTERFACES/TRAITS)
// ============================================================================

// Numeric protocol: Numbers support +, -, *, /
protocol Numeric {
  function add(other: Self) -> Self
  function sub(other: Self) -> Self
  function mul(other: Self) -> Self
  function div(other: Self) -> Self
}

// Stringifiable protocol: Can be converted to string
protocol Stringifiable {
  function to_string() -> String
}

// Equatable protocol: Supports equality comparison
protocol Equatable {
  function eq(other: Self) -> Bool
  function neq(other: Self) -> Bool
}

// Comparable protocol: Supports ordering
protocol Comparable : Equatable {
  function lt(other: Self) -> Bool
  function lte(other: Self) -> Bool
  function gt(other: Self) -> Bool
  function gte(other: Self) -> Bool
}

// Iterable protocol: Can be iterated
protocol Iterable[T] {
  function iter() -> Iterator[T]
  function len() -> Int
}

// ============================================================================
// 5. IMPLEMENTATIONS
// ============================================================================

// Numeric implementation for Int
impl Numeric for Int {
  function add(other: Int) -> Int = this + other
  function sub(other: Int) -> Int = this - other
  function mul(other: Int) -> Int = this * other
  function div(other: Int) -> Int = this / other
}

// Numeric implementation for Float
impl Numeric for Float {
  function add(other: Float) -> Float = this + other
  function sub(other: Float) -> Float = this - other
  function mul(other: Float) -> Float = this * other
  function div(other: Float) -> Float = this / other
}

// Stringifiable for Int
impl Stringifiable for Int {
  function to_string() -> String = format("{}", this)
}

// Stringifiable for String
impl Stringifiable for String {
  function to_string() -> String = this
}

// Equatable for Int
impl Equatable for Int {
  function eq(other: Int) -> Bool = this == other
  function neq(other: Int) -> Bool = this != other
}

// Comparable for Int
impl Comparable for Int {
  function eq(other: Int) -> Bool = this == other
  function neq(other: Int) -> Bool = this != other
  function lt(other: Int) -> Bool = this < other
  function lte(other: Int) -> Bool = this <= other
  function gt(other: Int) -> Bool = this > other
  function gte(other: Int) -> Bool = this >= other
}

// ============================================================================
// 6. TYPE CONSTRAINTS & BOUNDS
// ============================================================================

// Generic function with trait bounds
function max[T: Comparable](a: T, b: T) -> T = {
  if a.gt(b) { a } else { b }
}

function min[T: Comparable](a: T, b: T) -> T = {
  if a.lt(b) { a } else { b }
}

function sum[T: Numeric](items: [T]) -> T = {
  fold(items, zero[T](), fn(acc, x) -> acc.add(x))
}

// ============================================================================
// 7. HELPER FUNCTIONS
// ============================================================================

function typeof_string(d: Dynamic) -> String = dynamic_typeof(d)

function is_dynamic(d: Dynamic) -> Bool = true

function to_dynamic[T](x: T) -> Dynamic = match x {
  // Type conversion logic
  // This is simplified - real implementation needs more cases
  _ -> Nil
}

// Panic function (error handling)
function panic(msg: String) -> !Never = {
  // Print error and exit
  println(format("PANIC: {}", msg))
  exit(1)
}

// Iterator trait for generic iteration
type Iterator[T] = record {
  next: fn() -> Option[T],
  has_next: fn() -> Bool
}

