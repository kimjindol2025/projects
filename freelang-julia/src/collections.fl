module collections

import types_extended

// ============================================================================
// 1. TUPLE TYPES
// ============================================================================

// Homogeneous tuple
type Tuple[T] =
  | Tuple1(T)
  | Tuple2(T, T)
  | Tuple3(T, T, T)
  | Tuple4(T, T, T, T)

// Heterogeneous tuple (dynamic)
type DynTuple =
  | DynTuple2(Dynamic, Dynamic)
  | DynTuple3(Dynamic, Dynamic, Dynamic)
  | DynTuple4(Dynamic, Dynamic, Dynamic, Dynamic)

// Create 2-tuple
function tuple2[A, B](a: A, b: B) -> Pair[A, B] = {
  Pair { first: a, second: b }
}

// Create 3-tuple (using nested pairs)
record Tuple3Wrapper[A, B, C] {
  first: A,
  second: B,
  third: C
}

function tuple3[A, B, C](a: A, b: B, c: C) -> Tuple3Wrapper[A, B, C] = {
  Tuple3Wrapper { first: a, second: b, third: c }
}

// ============================================================================
// 2. NAMED TUPLE
// ============================================================================

record NamedTuple {
  fields: Map[String, Dynamic],
  names: [String]
}

function named_tuple(names: [String], values: [Dynamic]) -> NamedTuple = {
  let fields = Map::new[String, Dynamic]()
  fold_pairs(names, values, fields, fn(m, name, val) -> {
    m.set(name, val)
    m
  })
  NamedTuple {
    fields: fields,
    names: names
  }
}

// Access named tuple field
function get_field(nt: NamedTuple, name: String) -> Option[Dynamic] = {
  nt.fields.get(name)
}

// ============================================================================
// 3. DICTIONARY (MAP) TYPE
// ============================================================================

record Dict[K, V] {
  entries: [(K, V)],
  size: Int
}

// Create empty dictionary
function new_dict[K, V]() -> Dict[K, V] = {
  Dict {
    entries: [],
    size: 0
  }
}

// Create dictionary from pairs
function dict[K, V](pairs: [(K, V)]) -> Dict[K, V] = {
  Dict {
    entries: pairs,
    size: len(pairs)
  }
}

// Insert key-value pair
function insert[K, V](d: mutable Dict[K, V], key: K, value: V) -> Unit = {
  // Check if key exists and update
  let found = fold(d.entries, false, fn(acc, pair) -> {
    if pair.0 == key {
      pair.1 = value
      true
    } else {
      acc
    }
  })

  if !found {
    d.entries = append(d.entries, (key, value))
    d.size = d.size + 1
  }
}

// Get value by key
function lookup[K, V](d: Dict[K, V], key: K) -> Option[V] = {
  fold(d.entries, None, fn(acc, pair) -> {
    if pair.0 == key {
      Some(pair.1)
    } else {
      acc
    }
  })
}

// Check if key exists
function has_key[K, V](d: Dict[K, V], key: K) -> Bool = {
  match lookup(d, key) {
    Some(_) -> true,
    None -> false
  }
}

// Remove key
function remove[K, V](d: mutable Dict[K, V], key: K) -> Option[V] = {
  let result = fold(d.entries, None, fn(acc, pair) -> {
    if pair.0 == key {
      Some(pair.1)
    } else {
      acc
    }
  })

  d.entries = filter_pairs(d.entries, fn(pair) -> pair.0 != key)
  d.size = len(d.entries)
  result
}

// Get all keys
function keys[K, V](d: Dict[K, V]) -> [K] = {
  fold(d.entries, [], fn(acc, pair) -> {
    append(acc, pair.0)
  })
}

// Get all values
function values[K, V](d: Dict[K, V]) -> [V] = {
  fold(d.entries, [], fn(acc, pair) -> {
    append(acc, pair.1)
  })
}

// Dictionary size
function dict_len[K, V](d: Dict[K, V]) -> Int = d.size

// ============================================================================
// 4. SET TYPE
// ============================================================================

record Set[T] {
  elements: [T],
  size: Int
}

// Create empty set
function new_set[T]() -> Set[T] = {
  Set {
    elements: [],
    size: 0
  }
}

// Create set from elements
function set[T](items: [T]) -> Set[T] = {
  // Remove duplicates
  let unique = fold(items, [], fn(acc, item) -> {
    let found = fold(acc, false, fn(f, e) -> f || (e == item))
    if found {
      acc
    } else {
      append(acc, item)
    }
  })
  Set {
    elements: unique,
    size: len(unique)
  }
}

// Add element to set
function set_add[T](s: mutable Set[T], item: T) -> Unit = {
  let found = fold(s.elements, false, fn(acc, e) -> {
    acc || (e == item)
  })

  if !found {
    s.elements = append(s.elements, item)
    s.size = s.size + 1
  }
}

// Remove element from set
function set_remove[T](s: mutable Set[T], item: T) -> Bool = {
  let found = fold(s.elements, false, fn(acc, e) -> {
    acc || (e == item)
  })

  s.elements = filter_items(s.elements, fn(e) -> e != item)
  if found {
    s.size = s.size - 1
  }
  found
}

// Check membership
function set_contains[T](s: Set[T], item: T) -> Bool = {
  fold(s.elements, false, fn(acc, e) -> {
    acc || (e == item)
  })
}

// Set union
function set_union[T](s1: Set[T], s2: Set[T]) -> Set[T] = {
  let combined = s1.elements + s2.elements
  set(combined)
}

// Set intersection
function set_intersect[T](s1: Set[T], s2: Set[T]) -> Set[T] = {
  let result = fold(s1.elements, [], fn(acc, item) -> {
    if set_contains(s2, item) {
      append(acc, item)
    } else {
      acc
    }
  })
  Set { elements: result, size: len(result) }
}

// Set difference
function set_diff[T](s1: Set[T], s2: Set[T]) -> Set[T] = {
  let result = fold(s1.elements, [], fn(acc, item) -> {
    if !set_contains(s2, item) {
      append(acc, item)
    } else {
      acc
    }
  })
  Set { elements: result, size: len(result) }
}

// Set size
function set_len[T](s: Set[T]) -> Int = s.size

// ============================================================================
// 5. ORDERED PAIRS & KEY-VALUE
// ============================================================================

// Key-value pair
record KVPair[K, V] {
  key: K,
  value: V
}

function kv_pair[K, V](k: K, v: V) -> KVPair[K, V] = {
  KVPair { key: k, value: v }
}

// ============================================================================
// 6. HELPER FUNCTIONS
// ============================================================================

function append[T](arr: [T], item: T) -> [T] = {
  arr + [item]
}

function len[T](arr: [T]) -> Int = {
  // Built-in length
  count(arr, 0)
}

function count[T](arr: [T], acc: Int) -> Int = {
  if len_builtin(arr) == 0 {
    acc
  } else {
    count(tail(arr), acc + 1)
  }
}

function tail[T](arr: [T]) -> [T] = {
  if len_builtin(arr) <= 1 {
    []
  } else {
    slice(arr, 1, len_builtin(arr))
  }
}

function slice[T](arr: [T], start: Int, end: Int) -> [T] = {
  fold_index(0, len_builtin(arr), [], fn(acc, i) -> {
    if i >= start && i < end {
      append(acc, arr[i])
    } else {
      acc
    }
  })
}

function len_builtin[T](arr: [T]) -> Int = {
  // Native language length - simplified as 0 for this example
  0
}

function fold[T, U](items: [T], init: U, f: fn(U, T) -> U) -> U = {
  fold_impl(items, init, f, 0)
}

function fold_impl[T, U](items: [T], acc: U, f: fn(U, T) -> U, index: Int) -> U = {
  if len_builtin(items) == 0 {
    acc
  } else {
    fold_impl(tail(items), f(acc, items[0]), f, index + 1)
  }
}

function fold_index(start: Int, end: Int, initial: Any, f: fn(Any, Int) -> Any) -> Any = {
  if start >= end {
    initial
  } else {
    fold_index(start + 1, end, f(initial, start), f)
  }
}

function fold_pairs[K, V, R](keys: [K], values: [V], init: R, f: fn(R, K, V) -> R) -> R = {
  if len_builtin(keys) == 0 {
    init
  } else {
    fold_pairs(tail(keys), tail(values), f(init, keys[0], values[0]), f)
  }
}

function filter_pairs[K, V](pairs: [(K, V)], pred: fn((K, V)) -> Bool) -> [(K, V)] = {
  fold(pairs, [], fn(acc, pair) -> {
    if pred(pair) {
      append(acc, pair)
    } else {
      acc
    }
  })
}

function filter_items[T](items: [T], pred: fn(T) -> Bool) -> [T] = {
  fold(items, [], fn(acc, item) -> {
    if pred(item) {
      append(acc, item)
    } else {
      acc
    }
  })
}

// ============================================================================
// 7. TEST CASES (28 tests)
// ============================================================================

// Test 1: Create tuple2
function test_tuple2_create() -> Bool = {
  let t = tuple2[Int, String](1, "a")
  t.first == 1
}

// Test 2: Tuple2 second element
function test_tuple2_second() -> Bool = {
  let t = tuple2[Int, String](1, "a")
  t.second == "a"
}

// Test 3: Create tuple3
function test_tuple3_create() -> Bool = {
  let t = tuple3[Int, String, Bool](1, "a", true)
  t.first == 1
}

// Test 4: Tuple3 access
function test_tuple3_access() -> Bool = {
  let t = tuple3[Int, String, Bool](1, "a", true)
  t.third == true
}

// Test 5: Create empty dict
function test_dict_create() -> Bool = {
  let d = new_dict[String, Int]()
  dict_len(d) == 0
}

// Test 6: Dict insert
function test_dict_insert() -> Bool = {
  let d = new_dict[String, Int]()
  insert(d, "a", 1)
  dict_len(d) == 1
}

// Test 7: Dict lookup
function test_dict_lookup() -> Bool = {
  let d = dict[String, Int]([("a", 1), ("b", 2)])
  match lookup(d, "a") {
    Some(v) -> v == 1,
    None -> false
  }
}

// Test 8: Dict has_key
function test_dict_has_key() -> Bool = {
  let d = dict[String, Int]([("a", 1)])
  has_key(d, "a")
}

// Test 9: Dict remove
function test_dict_remove() -> Bool = {
  let d = dict[String, Int]([("a", 1), ("b", 2)])
  match remove(d, "a") {
    Some(v) -> v == 1 && dict_len(d) == 1,
    None -> false
  }
}

// Test 10: Dict keys
function test_dict_keys() -> Bool = {
  let d = dict[String, Int]([("a", 1), ("b", 2)])
  len(keys(d)) == 2
}

// Test 11: Dict values
function test_dict_values() -> Bool = {
  let d = dict[String, Int]([("a", 1), ("b", 2)])
  len(values(d)) == 2
}

// Test 12: Dict from pairs
function test_dict_from_pairs() -> Bool = {
  let pairs = [("x", 10), ("y", 20)]
  let d = dict[String, Int](pairs)
  dict_len(d) == 2
}

// Test 13: Create set
function test_set_create() -> Bool = {
  let s = set[Int]([1, 2, 3])
  set_len(s) == 3
}

// Test 14: Set add
function test_set_add() -> Bool = {
  let s = new_set[Int]()
  set_add(s, 1)
  set_len(s) == 1
}

// Test 15: Set contains
function test_set_contains() -> Bool = {
  let s = set[Int]([1, 2, 3])
  set_contains(s, 2)
}

// Test 16: Set remove
function test_set_remove() -> Bool = {
  let s = set[Int]([1, 2, 3])
  set_remove(s, 2)
  set_len(s) == 2
}

// Test 17: Set union
function test_set_union() -> Bool = {
  let s1 = set[Int]([1, 2])
  let s2 = set[Int]([2, 3])
  let u = set_union(s1, s2)
  set_len(u) == 3
}

// Test 18: Set intersection
function test_set_intersect() -> Bool = {
  let s1 = set[Int]([1, 2, 3])
  let s2 = set[Int]([2, 3, 4])
  let i = set_intersect(s1, s2)
  set_len(i) == 2
}

// Test 19: Set difference
function test_set_diff() -> Bool = {
  let s1 = set[Int]([1, 2, 3])
  let s2 = set[Int]([2])
  let d = set_diff(s1, s2)
  set_len(d) == 2
}

// Test 20: Set duplicate removal
function test_set_duplicates() -> Bool = {
  let s = set[Int]([1, 1, 2, 2, 3])
  set_len(s) == 3
}

// Test 21: KV pair create
function test_kv_pair() -> Bool = {
  let kv = kv_pair[String, Int]("age", 25)
  kv.key == "age"
}

// Test 22: KV pair value
function test_kv_pair_value() -> Bool = {
  let kv = kv_pair[String, Int]("age", 25)
  kv.value == 25
}

// Test 23: Named tuple create
function test_named_tuple_create() -> Bool = {
  let names = ["x", "y"]
  let values = [Dynamic::Int(1), Dynamic::Int(2)]
  let nt = named_tuple(names, values)
  len(nt.names) == 2
}

// Test 24: Named tuple field access
function test_named_tuple_field() -> Bool = {
  let names = ["x"]
  let values = [Dynamic::Int(42)]
  let nt = named_tuple(names, values)
  match get_field(nt, "x") {
    Some(d) -> true,
    None -> false
  }
}

// Test 25: Dict empty check
function test_dict_empty() -> Bool = {
  let d = new_dict[String, Int]()
  dict_len(d) == 0
}

// Test 26: Set empty check
function test_set_empty() -> Bool = {
  let s = new_set[Int]()
  set_len(s) == 0
}

// Test 27: Dict lookup miss
function test_dict_lookup_miss() -> Bool = {
  let d = dict[String, Int]([("a", 1)])
  match lookup(d, "z") {
    Some(_) -> false,
    None -> true
  }
}

// Test 28: Set not contains
function test_set_not_contains() -> Bool = {
  let s = set[Int]([1, 2, 3])
  !set_contains(s, 5)
}

