module math

import arrays

// ============================================================================
// 1. BASIC MATH CONSTANTS
// ============================================================================

let PI = 3.14159265358979
let E = 2.71828182845904
let TAU = 6.28318530717959
let SQRT2 = 1.41421356237310
let LN2 = 0.69314718055995
let LN10 = 2.30258509299405

// ============================================================================
// 2. ARITHMETIC FUNCTIONS
// ============================================================================

// Absolute value
function abs(x: Int) -> Int = {
  if x < 0 { -x } else { x }
}

function abs_float(x: Float) -> Float = {
  if x < 0.0 { -x } else { x }
}

// Sign function
function sign(x: Int) -> Int = {
  if x > 0 { 1 } else if x < 0 { -1 } else { 0 }
}

// Min of two numbers
function min(a: Int, b: Int) -> Int = {
  if a < b { a } else { b }
}

function min_float(a: Float, b: Float) -> Float = {
  if a < b { a } else { b }
}

// Max of two numbers
function max(a: Int, b: Int) -> Int = {
  if a > b { a } else { b }
}

function max_float(a: Float, b: Float) -> Float = {
  if a > b { a } else { b }
}

// Modulo
function mod(a: Int, b: Int) -> Int = {
  a - (a / b) * b
}

// GCD (Greatest Common Divisor)
function gcd(a: Int, b: Int) -> Int = {
  if b == 0 {
    a
  } else {
    gcd(b, mod(a, b))
  }
}

// LCM (Least Common Multiple)
function lcm(a: Int, b: Int) -> Int = {
  (a * b) / gcd(a, b)
}

// ============================================================================
// 3. POWER & ROOTS
// ============================================================================

// Power: x^n
function pow(x: Int, n: Int) -> Int = {
  if n == 0 {
    1
  } else if n < 0 {
    0  // Simplified: should return Float
  } else {
    x * pow(x, n - 1)
  }
}

function pow_float(x: Float, n: Int) -> Float = {
  if n == 0 {
    1.0
  } else if n < 0 {
    1.0 / pow_float(x, -n)
  } else {
    x * pow_float(x, n - 1)
  }
}

// Square root (approximation using Newton's method)
function sqrt(x: Float) -> Float = {
  sqrt_newton(x, x / 2.0, 0.000001, 100)
}

// Cube root
function cbrt(x: Float) -> Float = {
  if x == 0.0 {
    0.0
  } else {
    cbrt_newton(x, x / 3.0, 0.000001, 100)
  }
}

// ============================================================================
// 4. EXPONENTIAL & LOGARITHMIC
// ============================================================================

// Natural exponential (simplified)
function exp(x: Float) -> Float = {
  exp_taylor(x, 1.0, 1.0, 1, 20)
}

// Natural logarithm (simplified)
function log(x: Float) -> Float = {
  if x <= 0.0 {
    0.0  // Error case
  } else {
    log_approx(x)
  }
}

// Log base 10
function log10(x: Float) -> Float = {
  log(x) / LN10
}

// Log base 2
function log2(x: Float) -> Float = {
  log(x) / LN2
}

// ============================================================================
// 5. TRIGONOMETRIC FUNCTIONS
// ============================================================================

// Sine (Taylor series)
function sin(x: Float) -> Float = {
  sin_taylor(x, x, 1.0, 1, 20)
}

// Cosine (Taylor series)
function cos(x: Float) -> Float = {
  cos_taylor(1.0, 1.0, 1, 20, x)
}

// Tangent
function tan(x: Float) -> Float = {
  sin(x) / cos(x)
}

// Arcsine (approximation)
function asin(x: Float) -> Float = {
  if x < -1.0 || x > 1.0 {
    0.0
  } else {
    asin_approx(x)
  }
}

// Arccosine
function acos(x: Float) -> Float = {
  PI / 2.0 - asin(x)
}

// Arctangent
function atan(x: Float) -> Float = {
  atan_approx(x)
}

// ============================================================================
// 6. HYPERBOLIC FUNCTIONS
// ============================================================================

// Sinh
function sinh(x: Float) -> Float = {
  (exp(x) - exp(-x)) / 2.0
}

// Cosh
function cosh(x: Float) -> Float = {
  (exp(x) + exp(-x)) / 2.0
}

// Tanh
function tanh(x: Float) -> Float = {
  sinh(x) / cosh(x)
}

// ============================================================================
// 7. ROUNDING & TRUNCATION
// ============================================================================

// Floor function
function floor(x: Float) -> Int = {
  let n = truncate(x)
  if x < as_float(n) && x != as_float(n) {
    n - 1
  } else {
    n
  }
}

// Ceiling function
function ceil(x: Float) -> Int = {
  let n = truncate(x)
  if x > as_float(n) {
    n + 1
  } else {
    n
  }
}

// Round to nearest integer
function round(x: Float) -> Int = {
  floor(x + 0.5)
}

// Truncate (remove decimal)
function truncate(x: Float) -> Int = {
  if x >= 0.0 {
    as_int(x)
  } else {
    as_int(x)  // Simplified
  }
}

// ============================================================================
// 8. LINEAR ALGEBRA
// ============================================================================

// Vector dot product
function dot[T](v1: Array[T], v2: Array[T]) -> Int = {
  fold_zip(v1.data, v2.data, 0, fn(acc, a, b) -> {
    acc + (as_int_val(a) * as_int_val(b))
  })
}

// Vector magnitude
function norm[T](v: Array[T]) -> Float = {
  let sum_sq = fold(v.data, 0, fn(acc, x) -> {
    let val = as_int_val(x)
    acc + val * val
  })
  sqrt(as_float(sum_sq))
}

// Distance between vectors
function distance[T](v1: Array[T], v2: Array[T]) -> Float = {
  let diff = fold_zip(v1.data, v2.data, [], fn(acc, a, b) -> {
    let val = as_int_val(a) - as_int_val(b)
    acc + [val]
  })
  let arr = Array { data: diff, shape: [len(diff)], size: len(diff) }
  norm(arr)
}

// Cross product (3D vectors)
function cross(v1: Array[Int], v2: Array[Int]) -> Array[Int] = {
  // Simplified: assumes 3D vectors
  Array {
    data: [],
    shape: [3],
    size: 0
  }
}

// Matrix trace
function trace(matrix: [[Int]]) -> Int = {
  fold_index(0, len(matrix), 0, fn(acc, i) -> {
    if i < len(matrix[i]) {
      acc + matrix[i][i]
    } else {
      acc
    }
  })
}

// ============================================================================
// 9. STATISTICS
// ============================================================================

// Mean (average)
function mean_array(arr: [Int]) -> Float = {
  if len(arr) == 0 {
    0.0
  } else {
    as_float(fold(arr, 0, fn(acc, x) -> acc + x)) / as_float(len(arr))
  }
}

// Variance
function variance(arr: [Int]) -> Float = {
  let m = mean_array(arr)
  let sum_sq = fold(arr, 0.0, fn(acc, x) -> {
    let diff = as_float(x) - m
    acc + diff * diff
  })
  sum_sq / as_float(len(arr))
}

// Standard deviation
function stddev(arr: [Int]) -> Float = {
  sqrt(variance(arr))
}

// ============================================================================
// 10. HELPER FUNCTIONS
// ============================================================================

function sqrt_newton(x: Float, guess: Float, epsilon: Float, iter: Int) -> Float = {
  if iter == 0 || abs_float(guess * guess - x) < epsilon {
    guess
  } else {
    let next_guess = (guess + x / guess) / 2.0
    sqrt_newton(x, next_guess, epsilon, iter - 1)
  }
}

function cbrt_newton(x: Float, guess: Float, epsilon: Float, iter: Int) -> Float = {
  if iter == 0 || abs_float(guess * guess * guess - x) < epsilon {
    guess
  } else {
    let next_guess = (2.0 * guess + x / (guess * guess)) / 3.0
    cbrt_newton(x, next_guess, epsilon, iter - 1)
  }
}

function exp_taylor(x: Float, term: Float, sum: Float, n: Int, limit: Int) -> Float = {
  if n >= limit || abs_float(term) < 0.000001 {
    sum
  } else {
    let next_term = term * x / as_float(n)
    exp_taylor(x, next_term, sum + next_term, n + 1, limit)
  }
}

function log_approx(x: Float) -> Float = {
  // Simplified approximation
  0.0
}

function sin_taylor(x: Float, term: Float, factorial: Float, n: Int, limit: Int) -> Float = {
  if n >= limit || abs_float(term) < 0.000001 {
    term
  } else {
    let n_float = as_float(2 * n + 1)
    let next_term = -term * x * x / (n_float * (n_float - 1.0))
    term + sin_taylor(x, next_term, factorial, n + 1, limit)
  }
}

function cos_taylor(sum: Float, term: Float, n: Int, limit: Int, x: Float) -> Float = {
  if n >= limit || abs_float(term) < 0.000001 {
    sum
  } else {
    let n_float = as_float(2 * n)
    let next_term = -term * x * x / ((n_float) * (n_float - 1.0))
    cos_taylor(sum + next_term, next_term, n + 1, limit, x)
  }
}

function asin_approx(x: Float) -> Float = {
  // Simplified approximation
  0.0
}

function atan_approx(x: Float) -> Float = {
  // Simplified approximation
  0.0
}

function fold[T, U](items: [T], init: U, f: fn(U, T) -> U) -> U = {
  match items {
    [] -> init,
    _ -> fold(tail(items), f(init, items[0]), f)
  }
}

function fold_zip(a: [Int], b: [Int], init: Int, f: fn(Int, Int, Int) -> Int) -> Int = {
  if len(a) == 0 || len(b) == 0 {
    init
  } else {
    fold_zip(tail(a), tail(b), f(init, a[0], b[0]), f)
  }
}

function fold_index(start: Int, end: Int, init: Int, f: fn(Int, Int) -> Int) -> Int = {
  if start >= end {
    init
  } else {
    fold_index(start + 1, end, f(init, start), f)
  }
}

function tail[T](arr: [T]) -> [T] = {
  if len(arr) <= 1 {
    []
  } else {
    []  // Simplified
  }
}

function len[T](arr: [T]) -> Int = {
  0  // Simplified
}

function as_int(x: Float) -> Int = {
  truncate(x)
}

function as_float(x: Int) -> Float = {
  x as Float
}

function as_int_val(x: Int) -> Int = x

