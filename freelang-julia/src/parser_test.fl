# ============================================================================
# Phase C Task C.2: Parser 테스트 (14개 테스트 케이스)
# ============================================================================

# Test 1: 정수 리터럴 파싱
function test_integer_literal(): Bool =
  let lex = new_lexer("42")
  let tokens = tokenize(lex)
  let parser = new_parser(tokens)
  let (_, result) = parse_program(parser)
  match result {
    Ok(prog) -> prog.statements.length > 0,
    Err(_) -> false,
  }

# Test 2: 부동소수점 리터럴 파싱
function test_float_literal(): Bool =
  let lex = new_lexer("3.14")
  let tokens = tokenize(lex)
  let parser = new_parser(tokens)
  let (_, result) = parse_program(parser)
  match result {
    Ok(prog) -> prog.statements.length > 0,
    Err(_) -> false,
  }

# Test 3: 문자열 리터럴 파싱
