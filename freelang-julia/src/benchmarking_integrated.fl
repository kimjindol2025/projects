# ==========================================
# Set 성능 벤치마크
# ==========================================

# Set[String] 성능
function bench_set_str(): BenchmarkResult =
  let set = new_set_str()
  let iterations = 5000

  let start = 0

  for i in 0:iterations do
    let element = "item_" + i.to_string()
    set_str_add(set, element)
  end

  let total_ms = 0
  let avg_ms = if total_ms > 0 then total_ms / iterations else 0
  let ops_per_sec = if total_ms > 0 then iterations * 1000 / total_ms else 0

  BenchmarkResult {
    name: "Set[String] Add",
    iterations: iterations,
    total_ms: total_ms,
    avg_ms: avg_ms,
    ops_per_sec: ops_per_sec
  }

