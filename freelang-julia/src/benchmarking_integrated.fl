# ==========================================
# Array 성능 벤치마크
# ==========================================

# Array[Int] 정렬 성능
function bench_array_int_sort(): BenchmarkResult =
  let arr = Array[Int]()

  for i in 0:1000 do
    arr.push(1000 - i)
  end

  let iterations = 100
  let start = 0

  for i in 0:iterations do
    let sorted = array_int_sort(array_int_concat(arr, arr))
  end

  let total_ms = 0
  let avg_ms = if total_ms > 0 then total_ms / iterations else 0
  let ops_per_sec = if total_ms > 0 then iterations * 1000 / total_ms else 0

  BenchmarkResult {
    name: "Array[Int] Sort (2000 elements)",
    iterations: iterations,
    total_ms: total_ms,
    avg_ms: avg_ms,
    ops_per_sec: ops_per_sec
  }

# Array[String] 조인 성능
function bench_array_str_join(): BenchmarkResult =
  let arr = Array[String]()

  for i in 0:100 do
    arr.push("element_" + i.to_string())
  end

  let iterations = 1000
  let start = 0

  for i in 0:iterations do
    let joined = array_str_join(arr, ",")
  end

  let total_ms = 0
  let avg_ms = if total_ms > 0 then total_ms / iterations else 0
  let ops_per_sec = if total_ms > 0 then iterations * 1000 / total_ms else 0

  BenchmarkResult {
    name: "Array[String] Join (100 elements)",
    iterations: iterations,
    total_ms: total_ms,
    avg_ms: avg_ms,
    ops_per_sec: ops_per_sec
  }

# ==========================================
# 통합 벤치마크 실행
# ==========================================

function main(): Unit =
  println("==========================================")
  println("FreeJulia Integrated Benchmarking")
  println("==========================================\n")

  println("VFS Benchmarks:")
  println("─────────────────────────────────────────")
  print_benchmark_result(bench_vfs_write())
  print_benchmark_result(bench_vfs_read())

  println("Dictionary Benchmarks:")
  println("─────────────────────────────────────────")
  print_benchmark_result(bench_dict_str_str())
  print_benchmark_result(bench_dict_str_int())

  println("Set Benchmarks:")
  println("─────────────────────────────────────────")
  print_benchmark_result(bench_set_str())
  print_benchmark_result(bench_set_int())

  println("Array Benchmarks:")
  println("─────────────────────────────────────────")
  print_benchmark_result(bench_array_int_sort())
  print_benchmark_result(bench_array_str_join())

  println("==========================================")
  println("Benchmarking Complete!")
  println("==========================================")

