# ==========================================
# Phase G Task G.2: Generic Collections
# (모든 타입을 지원하는 Collections)
# ==========================================
# Polymorphic Collections Implementation
#
# FreeJulia의 제너릭 제약으로 인해, 여러 구체적 구현을 제공합니다:
# - Dictionary[String, String]
# - Dictionary[String, Int]
# - Dictionary[Int, String]
# - Set[String]
# - Set[Int]
# - Array[String]
# - Array[Int]

# ==========================================
# 기본 타입 정의
# ==========================================

# Key-Value 쌍 (String keys, String values)
record KeyValueStr =
  key: String
  value: String

# Key-Value 쌍 (String keys, Int values)
record KeyValueStrInt =
  key: String
  value: Int

# Key-Value 쌍 (Int keys, String values)
record KeyValueIntStr =
  key: Int
  value: String

# Key-Value 쌍 (Int keys, Int values)
record KeyValueIntInt =
  key: Int
  value: Int

# ==========================================
# Dictionary[String, String] (개선판)
# ==========================================

record DictionaryStrStr =
  entries: Array[KeyValueStr]
  size: Int

function new_dict_str_str(): DictionaryStrStr =
  DictionaryStrStr {
    entries: [],
    size: 0
  }

function dict_str_str_set(dict: DictionaryStrStr, key: String, value: String): Void =
  for i in 0:dict.entries.length() do
    if dict.entries[i].key == key then
      dict.entries[i].value = value
      return
    end
  end

  dict.entries.push(KeyValueStr {
    key: key,
    value: value
  })
  dict.size = dict.size + 1

function dict_str_str_get(dict: DictionaryStrStr, key: String): Option[String] =
  for entry in dict.entries do
    if entry.key == key then
      return Some(entry.value)
    end
  end
  None

function dict_str_str_contains(dict: DictionaryStrStr, key: String): Bool =
  match dict_str_str_get(dict, key) {
    Some(_) -> true,
    None -> false
  }

function dict_str_str_remove(dict: DictionaryStrStr, key: String): Option[String] =
  for i in 0:dict.entries.length() do
    if dict.entries[i].key == key then
      let value = dict.entries[i].value
      dict.size = dict.size - 1
      return Some(value)
    end
  end
  None

function dict_str_str_clear(dict: DictionaryStrStr): Void =
  dict.entries = Array[KeyValueStr]()
  dict.size = 0

function dict_str_str_keys(dict: DictionaryStrStr): Array[String] =
  let keys = Array[String]()
  for entry in dict.entries do
    keys.push(entry.key)
  end
  keys

function dict_str_str_values(dict: DictionaryStrStr): Array[String] =
  let values = Array[String]()
  for entry in dict.entries do
    values.push(entry.value)
  end
  values

function dict_str_str_size(dict: DictionaryStrStr): Int =
  dict.size

# ==========================================
# Dictionary[String, Int]
# ==========================================

record DictionaryStrInt =
  entries: Array[KeyValueStrInt]
  size: Int

function new_dict_str_int(): DictionaryStrInt =
  DictionaryStrInt {
    entries: [],
    size: 0
  }

function dict_str_int_set(dict: DictionaryStrInt, key: String, value: Int): Void =
  for i in 0:dict.entries.length() do
    if dict.entries[i].key == key then
      dict.entries[i].value = value
      return
    end
  end

  dict.entries.push(KeyValueStrInt {
    key: key,
    value: value
  })
  dict.size = dict.size + 1

function dict_str_int_get(dict: DictionaryStrInt, key: String): Option[Int] =
  for entry in dict.entries do
    if entry.key == key then
      return Some(entry.value)
    end
  end
  None

function dict_str_int_contains(dict: DictionaryStrInt, key: String): Bool =
  match dict_str_int_get(dict, key) {
    Some(_) -> true,
    None -> false
  }

function dict_str_int_remove(dict: DictionaryStrInt, key: String): Option[Int] =
  for i in 0:dict.entries.length() do
    if dict.entries[i].key == key then
      let value = dict.entries[i].value
      dict.size = dict.size - 1
      return Some(value)
    end
  end
  None

function dict_str_int_clear(dict: DictionaryStrInt): Void =
  dict.entries = Array[KeyValueStrInt]()
  dict.size = 0

function dict_str_int_keys(dict: DictionaryStrInt): Array[String] =
  let keys = Array[String]()
  for entry in dict.entries do
    keys.push(entry.key)
  end
  keys

function dict_str_int_values(dict: DictionaryStrInt): Array[Int] =
  let values = Array[Int]()
  for entry in dict.entries do
    values.push(entry.value)
  end
  values

function dict_str_int_size(dict: DictionaryStrInt): Int =
  dict.size

# ==========================================
# Set[String]
# ==========================================

record SetStr =
  elements: Array[String]
  size: Int

function new_set_str(): SetStr =
  SetStr {
    elements: [],
    size: 0
  }

function set_str_add(set: SetStr, element: String): Void =
  for e in set.elements do
    if e == element then
      return
    end
  end

  set.elements.push(element)
  set.size = set.size + 1

function set_str_contains(set: SetStr, element: String): Bool =
  for e in set.elements do
    if e == element then
      return true
    end
  end
  false

function set_str_remove(set: SetStr, element: String): Bool =
  for i in 0:set.elements.length() do
    if set.elements[i] == element then
      set.size = set.size - 1
      return true
    end
  end
  false

function set_str_clear(set: SetStr): Void =
  set.elements = Array[String]()
  set.size = 0

function set_str_size(set: SetStr): Int =
  set.size

function set_str_union(set1: SetStr, set2: SetStr): SetStr =
  let result = new_set_str()

  for e in set1.elements do
    set_str_add(result, e)
  end

  for e in set2.elements do
    set_str_add(result, e)
  end

  result

function set_str_intersection(set1: SetStr, set2: SetStr): SetStr =
  let result = new_set_str()

  for e in set1.elements do
    if set_str_contains(set2, e) then
      set_str_add(result, e)
    end
  end

  result

function set_str_difference(set1: SetStr, set2: SetStr): SetStr =
  let result = new_set_str()

  for e in set1.elements do
    if not set_str_contains(set2, e) then
      set_str_add(result, e)
    end
  end

  result

# ==========================================
# Set[Int]
# ==========================================

record SetInt =
  elements: Array[Int]
  size: Int

function new_set_int(): SetInt =
  SetInt {
    elements: [],
