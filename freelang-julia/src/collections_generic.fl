# ==========================================
# Array[String] 유틸리티
# ==========================================

function array_str_sort(arr: Array[String]): Array[String] =
  let n = arr.length()
  for i in 0:n do
    for j in 0:(n - i - 1) do
      if arr[j] > arr[j + 1] then
        let temp = arr[j]
        arr[j] = arr[j + 1]
        arr[j + 1] = temp
      end
    end
  end
  arr

function array_str_reverse(arr: Array[String]): Array[String] =
  let result = Array[String]()
  for i in (arr.length() - 1):-1:(-1) do
    result.push(arr[i])
  end
  result

function array_str_join(arr: Array[String], separator: String): String =
  if arr.length() == 0 then
    return ""
  end

  let result = arr[0]
  for i in 1:arr.length() do
    result = result + separator + arr[i]
  end
  result

function array_str_concat(arr1: Array[String], arr2: Array[String]): Array[String] =
  let result = Array[String]()
  for x in arr1 do
    result.push(x)
  end
  for x in arr2 do
    result.push(x)
  end
  result

# ==========================================
# Array[Int] 유틸리티
# ==========================================

function array_int_sort(arr: Array[Int]): Array[Int] =
  let n = arr.length()
  for i in 0:n do
    for j in 0:(n - i - 1) do
      if arr[j] > arr[j + 1] then
        let temp = arr[j]
        arr[j] = arr[j + 1]
        arr[j + 1] = temp
      end
    end
  end
  arr

function array_int_reverse(arr: Array[Int]): Array[Int] =
  let result = Array[Int]()
  for i in (arr.length() - 1):-1:(-1) do
    result.push(arr[i])
  end
  result

function array_int_sum(arr: Array[Int]): Int =
  let sum = 0
  for x in arr do
    sum = sum + x
  end
  sum

function array_int_max(arr: Array[Int]): Option[Int] =
  if arr.length() == 0 then
    return None
  end

  let max = arr[0]
  for i in 1:arr.length() do
    if arr[i] > max then
      max = arr[i]
    end
  end
  Some(max)

function array_int_min(arr: Array[Int]): Option[Int] =
  if arr.length() == 0 then
    return None
  end

  let min = arr[0]
  for i in 1:arr.length() do
    if arr[i] < min then
      min = arr[i]
    end
  end
  Some(min)

function array_int_concat(arr1: Array[Int], arr2: Array[Int]): Array[Int] =
  let result = Array[Int]()
  for x in arr1 do
    result.push(x)
  end
  for x in arr2 do
    result.push(x)
  end
  result

# ==========================================
# 편의 함수 (레거시 호환성)
# ==========================================

# 기본값: String 기반
function new_dict(): DictionaryStrStr =
  new_dict_str_str()

function dict_set(dict: DictionaryStrStr, key: String, value: String): Void =
  dict_str_str_set(dict, key, value)

function dict_get(dict: DictionaryStrStr, key: String): Option[String] =
  dict_str_str_get(dict, key)

function dict_contains(dict: DictionaryStrStr, key: String): Bool =
  dict_str_str_contains(dict, key)

function dict_remove(dict: DictionaryStrStr, key: String): Option[String] =
  dict_str_str_remove(dict, key)

function dict_clear(dict: DictionaryStrStr): Void =
  dict_str_str_clear(dict)

function dict_keys(dict: DictionaryStrStr): Array[String] =
  dict_str_str_keys(dict)

function dict_values(dict: DictionaryStrStr): Array[String] =
  dict_str_str_values(dict)

function dict_size(dict: DictionaryStrStr): Int =
  dict_str_str_size(dict)

# 기본값: String 기반
function new_set(): SetStr =
  new_set_str()

function set_add(set: SetStr, element: String): Void =
  set_str_add(set, element)

function set_contains(set: SetStr, element: String): Bool =
  set_str_contains(set, element)

function set_remove(set: SetStr, element: String): Bool =
  set_str_remove(set, element)

function set_clear(set: SetStr): Void =
  set_str_clear(set)

function set_size(set: SetStr): Int =
  set_str_size(set)

function set_union(set1: SetStr, set2: SetStr): SetStr =
  set_str_union(set1, set2)

function set_intersection(set1: SetStr, set2: SetStr): SetStr =
  set_str_intersection(set1, set2)

function set_difference(set1: SetStr, set2: SetStr): SetStr =
  set_str_difference(set1, set2)

