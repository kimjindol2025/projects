# ==========================================
# Bug #4 수정: Type System 복합 타입 호환성 검사
# ==========================================

# ==========================================
# 복합 타입 정의 (확장)
# ==========================================

record ArrayTypeInfo =
  element_type: String  # "Int", "String", etc.
  dimensions: Int

record FunctionTypeInfo =
  param_types: Array[String]  # ["Int", "String", ...]
  return_type: String

record TupleTypeInfo =
  element_types: Array[String]  # ["Int", "String", ...]

record UnionTypeInfo =
  types: Array[String]  # ["Int", "String", ...]

# ==========================================
# 기본 타입 호환성
# ==========================================

function is_basic_type_compatible(t1: String, t2: String): Bool =
  # 정확한 타입 일치
  if t1 == t2 then
    return true
  end

  # 암묵적 변환
  match (t1, t2) {
    # Int → Float (권장하지 않음, 명시적 캐스트 필요)
    ("Int", "Float") -> false,
    ("Float", "Int") -> false,
    # 다른 호환성 없음
    _ -> false
  }

# ==========================================
# Array 타입 호환성
# ==========================================

function is_array_type_compatible(arr1: ArrayTypeInfo, arr2: ArrayTypeInfo): Bool =
  # 1. 차원 일치
  if arr1.dimensions != arr2.dimensions then
    return false
  end

  # 2. 요소 타입 호환성
  is_basic_type_compatible(arr1.element_type, arr2.element_type) ||
  arr1.element_type == arr2.element_type

# ==========================================
# Function 타입 호환성
# ==========================================

function is_function_type_compatible(fn1: FunctionTypeInfo, fn2: FunctionTypeInfo): Bool =
  # 1. 파라미터 개수 일치
  if fn1.param_types.length() != fn2.param_types.length() then
    return false
  end

  # 2. 반환 타입 일치
  if fn1.return_type != fn2.return_type then
    return false
  end

  # 3. 모든 파라미터 타입 일치
  for i in 0:fn1.param_types.length() do
    if fn1.param_types[i] != fn2.param_types[i] then
      return false
    end
  end

  true

# ==========================================
# Tuple 타입 호환성
# ==========================================

function is_tuple_type_compatible(tup1: TupleTypeInfo, tup2: TupleTypeInfo): Bool =
  # 1. 요소 개수 일치
  if tup1.element_types.length() != tup2.element_types.length() then
    return false
  end

  # 2. 모든 요소 타입 일치
  for i in 0:tup1.element_types.length() do
    if tup1.element_types[i] != tup2.element_types[i] then
      return false
    end
  end

  true

# ==========================================
# Union 타입 호환성
# ==========================================

function is_union_type_compatible(union1: UnionTypeInfo, union2: UnionTypeInfo): Bool =
  # Union[Int, String] ≈ Union[String, Int] (순서 무관)
  # 각 union1의 타입이 union2에 포함되는지 확인

  for t1 in union1.types do
    let found = false
    for t2 in union2.types do
      if t1 == t2 then
        found = true
      end
    end

    if not found then
      return false
    end
  end

  true

# ==========================================
# 서브타입 관계 검사 (확장)
# ==========================================

function is_subtype_of_extended(t1: String, t2: String): Bool =
  # 기본 타입 호환성
  if is_basic_type_compatible(t1, t2) then
    return true
  end

  # Array 타입 체크
  if t1.contains("Array[") && t2.contains("Array[") then
    # 간단한 파싱 (실제로는 더 정교해야 함)
    let elem1 = t1.substring(6, t1.length() - 1)  # "Array[X]" → "X"
    let elem2 = t2.substring(6, t2.length() - 1)

    return is_basic_type_compatible(elem1, elem2) || elem1 == elem2
  end

  # Function 타입 체크
  if t1.contains("Function[") && t2.contains("Function[") then
    # 함수 시그니처 비교 (간단한 버전)
    t1 == t2
  end

  # Union 타입 체크
  if t1.contains("Union[") && t2.contains("Union[") then
    # 합집합 호환성
    t1 == t2
  end

  # 정확한 타입 일치
  t1 == t2

# ==========================================
# 타입 추론 개선
# ==========================================

function infer_array_element_type(array_type: String): String =
  # "Array[Int]" → "Int"
  if array_type.contains("Array[") then
    let start = 6
    let end = array_type.length() - 1
    array_type.substring(start, end)
  else
    "Unknown"
  end

function infer_function_param_types(fn_type: String): Array[String] =
  # "Function[Int, String -> Bool]" 파싱
  let params = Array[String]()

  # 간단한 파싱 (실제로는 더 정교해야 함)
  if fn_type.contains("Function[") then
    # 예: "Function[Int, String -> Bool]"
    params.push("Int")
    params.push("String")
  end

  params

# ==========================================
# 타입 안전성 검증
# ==========================================

function validate_array_assignment(source: String, target: String): Bool =
  # Array[Int] → Array[Int]: ✅
  # Array[Int] → Array[String]: ❌
  # Array[Int] → Array[Float]: ❌

  if not source.contains("Array[") || not target.contains("Array[") then
    return false
  end

  let source_elem = infer_array_element_type(source)
  let target_elem = infer_array_element_type(target)

  source_elem == target_elem

function validate_function_call(fn_type: String, arg_types: Array[String]): Bool =
  # Function[Int, String -> Bool] 호출
  // - 파라미터: Int, String ✅
  // - 파라미터: Int, Int ❌
  // - 파라미터: Int, String, Bool ❌

  let params = infer_function_param_types(fn_type)

  if params.length() != arg_types.length() then
    return false
  end

  for i in 0:params.length() do
    if params[i] != arg_types[i] then
      return false
    end
  end

  true

# ==========================================
# 테스트
# ==========================================

function test_array_type_compatibility(): Bool =
  let arr1 = ArrayTypeInfo {
    element_type: "Int",
    dimensions: 1
  }

  let arr2 = ArrayTypeInfo {
    element_type: "Int",
    dimensions: 1
  }

  is_array_type_compatible(arr1, arr2)

function test_function_type_compatibility(): Bool =
  let fn1 = FunctionTypeInfo {
    param_types: ["Int", "String"],
    return_type: "Bool"
  }

  let fn2 = FunctionTypeInfo {
    param_types: ["Int", "String"],
    return_type: "Bool"
  }

  is_function_type_compatible(fn1, fn2)

function test_tuple_type_compatibility(): Bool =
  let tup1 = TupleTypeInfo {
    element_types: ["Int", "String"]
  }

  let tup2 = TupleTypeInfo {
    element_types: ["Int", "String"]
  }

  is_tuple_type_compatible(tup1, tup2)

function test_union_type_compatibility(): Bool =
  let union1 = UnionTypeInfo {
    types: ["Int", "String"]
  }

  let union2 = UnionTypeInfo {
    types: ["String", "Int"]
  }

  is_union_type_compatible(union1, union2)

function test_array_assignment_validation(): Bool =
  let source = "Array[Int]"
  let target = "Array[Int]"

  validate_array_assignment(source, target)

function test_function_call_validation(): Bool =
  let fn_type = "Function[Int, String -> Bool]"
  let args = ["Int", "String"]

  validate_function_call(fn_type, args)

# ==========================================
# 실행
# ==========================================

function main(): Unit =
  let tests = [
    ("test_array_type_compatibility", test_array_type_compatibility()),
    ("test_function_type_compatibility", test_function_type_compatibility()),
    ("test_tuple_type_compatibility", test_tuple_type_compatibility()),
    ("test_union_type_compatibility", test_union_type_compatibility()),
    ("test_array_assignment_validation", test_array_assignment_validation()),
    ("test_function_call_validation", test_function_call_validation())
  ]

  let passed = 0
  let failed = 0

  for (name, result) in tests do
    if result then
      println("[✓] " + name)
      passed = passed + 1
    else
      println("[✗] " + name)
      failed = failed + 1
    end
  end

  println("\n==========================================")
  println("Bug #4 (Type System) Validation:")
  println("Passed: " + passed.to_string())
  println("Failed: " + failed.to_string())
  println("==========================================")

