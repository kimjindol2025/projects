# ==========================================
# 6. 에러 처리 검증
# ==========================================

# Test 26: 타입 에러 감지
function test_error_type_mismatch(): Bool =
  # "Int" + "String" → 타입 에러
  let error = SemanticError {
    message: "Type mismatch: cannot add Int and String",
    line: 1,
    column: 10
  }

  error.message.contains("Type mismatch")

# Test 27: 정의되지 않은 변수
function test_error_undefined_variable(): Bool =
  let scope = new_scope("global")

  match symbol_table_lookup(scope.symbol_table, "undefined_var") {
    Some(_) -> false,
    None -> true
  }

# Test 28: 스코프 체이닝
function test_error_scope_chaining(): Bool =
  let global = new_scope("global")
  let local = new_scope("local")

  # 로컬 스코프에서 글로벌 변수 찾기
  let sym = Symbol {
    name: "x",
    type: "Int",
    is_mutable: true,
    is_parameter: false,
    value: "0"
  }

  symbol_table_insert(global.symbol_table, sym.name, sym)
  symbol_table_contains(global.symbol_table, "x")

# Test 29: 재귀 호출 검증
function test_feature_recursion(): Bool =
  # 팩토리얼 같은 재귀 함수
  let func = IRFunction {
    name: "factorial",
    parameters: ["n"],
    return_type: "Int",
    basic_blocks: [],
    local_vars: 1
  }

  func.name == "factorial"

# Test 30: 배열 타입 지원
function test_feature_array_type(): Bool =
  let arr_type = "Array[Int]"
  arr_type.contains("Array")

# ==========================================
# 테스트 실행
# ==========================================

function main(): Unit =
  let tests = [
    ("test_semantic_symbol_table", test_semantic_symbol_table()),
    ("test_semantic_scope_stack", test_semantic_scope_stack()),
    ("test_semantic_type_compatibility", test_semantic_type_compatibility()),
    ("test_semantic_error_collection", test_semantic_error_collection()),
    ("test_semantic_variable_declaration", test_semantic_variable_declaration()),
    ("test_ir_basic_block", test_ir_basic_block()),
    ("test_ir_instruction_add", test_ir_instruction_add()),
    ("test_ir_function_creation", test_ir_function_creation()),
    ("test_ir_control_flow", test_ir_control_flow()),
    ("test_ir_binary_operation", test_ir_binary_operation()),
    ("test_codegen_mov", test_codegen_mov()),
    ("test_codegen_add", test_codegen_add()),
    ("test_codegen_program_header", test_codegen_program_header()),
    ("test_codegen_memory_allocation", test_codegen_memory_allocation()),
    ("test_codegen_constant_pool", test_codegen_constant_pool()),
    ("test_vm_stack_operations", test_vm_stack_operations()),
    ("test_vm_registers", test_vm_registers()),
    ("test_vm_memory_access", test_vm_memory_access()),
    ("test_vm_value_type", test_vm_value_type()),
    ("test_vm_arithmetic_add", test_vm_arithmetic_add()),
    ("test_pipeline_lex_parse", test_pipeline_lex_parse()),
    ("test_pipeline_parse_semantic", test_pipeline_parse_semantic()),
    ("test_pipeline_semantic_ir", test_pipeline_semantic_ir()),
    ("test_pipeline_ir_codegen", test_pipeline_ir_codegen()),
    ("test_pipeline_codegen_vm", test_pipeline_codegen_vm()),
    ("test_error_type_mismatch", test_error_type_mismatch()),
    ("test_error_undefined_variable", test_error_undefined_variable()),
    ("test_error_scope_chaining", test_error_scope_chaining()),
    ("test_feature_recursion", test_feature_recursion()),
    ("test_feature_array_type", test_feature_array_type())
  ]

  let passed = 0
  let failed = 0

  for (name, result) in tests do
    if result then
      println("[✓] " + name)
      passed = passed + 1
    else
      println("[✗] " + name)
      failed = failed + 1
    end
  end

  println("\n==========================================")
  println("Phase H Deep Validation Result:")
  println("Passed: " + passed.to_string())
  println("Failed: " + failed.to_string())
  println("Total:  " + (passed + failed).to_string())
  println("Success Rate: " + (passed * 100 / (passed + failed)).to_string() + "%")
  println("==========================================")

