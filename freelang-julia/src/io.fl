// FreeLang Julia Integration: IO Module
// Phase B.5: File I/O, System Operations, Environment
// Status: 🟢 Implementation (100% - Complete)
// Tests: 24/24 target

module io

import string as str

// ============================================================================
// 1. CONSOLE I/O
// ============================================================================

// Print to stdout
function println(s: String) -> Unit = {
  print_impl(s + "\n")
}

// Print without newline
function print(s: String) -> Unit = {
  print_impl(s)
}

// Print with formatting
function printf(format: String, args: [String]) -> Unit = {
  let formatted = format_string(format, args)
  print_impl(formatted)
}

// Print error to stderr
function eprintln(s: String) -> Unit = {
  eprint_impl(s + "\n")
}

// ============================================================================
// 2. INPUT OPERATIONS
// ============================================================================

// Read line from stdin
function readline() -> Option[String] = {
  match read_line_impl() {
    Some(line) -> Some(line),
    None -> None
  }
}

// Read entire input
function read_all() -> String = {
  read_all_impl("")
}

// Read n characters
function read_chars(n: Int) -> String = {
  read_chars_impl(n, "")
}

// ============================================================================
// 3. FILE OPERATIONS
// ============================================================================

// File type
record File {
  path: String,
  handle: String,  // Internal file handle
  mode: String     // "r", "w", "a", "rw"
}

// Open file
function open(path: String, mode: String) -> Result[File, String] = {
  match open_file_impl(path, mode) {
    Some(handle) -> Ok(File { path: path, handle: handle, mode: mode }),
    None -> Err(format_error("Cannot open file", path))
  }
}

// Close file
function close(f: File) -> Result[Unit, String] = {
  match close_file_impl(f.handle) {
    true -> Ok(()),
    false -> Err("Failed to close file")
  }
}

// Read file content
function read_file(path: String) -> Result[String, String] = {
  match open(path, "r") {
    Ok(f) -> {
      let content = read_file_content(f.handle)
      match close(f) {
        Ok(_) -> Ok(content),
        Err(e) -> Err(e)
      }
    }
    Err(e) -> Err(e)
  }
}

// Write to file
function write_file(path: String, content: String) -> Result[Unit, String] = {
  match open(path, "w") {
    Ok(f) -> {
      write_file_content(f.handle, content)
      match close(f) {
        Ok(_) -> Ok(()),
        Err(e) -> Err(e)
      }
    }
    Err(e) -> Err(e)
  }
}

// Append to file
function append_file(path: String, content: String) -> Result[Unit, String] = {
  match open(path, "a") {
    Ok(f) -> {
      write_file_content(f.handle, content)
      match close(f) {
        Ok(_) -> Ok(()),
        Err(e) -> Err(e)
      }
    }
    Err(e) -> Err(e)
  }
}

// Write to file handle
function fwrite(f: File, content: String) -> Result[Unit, String] = {
  match write_file_content_impl(f.handle, content) {
    true -> Ok(()),
    false -> Err("Write failed")
  }
}

// Read from file handle
function fread(f: File) -> Result[String, String] = {
  Ok(read_file_content(f.handle))
}

// Read line from file
function freadline(f: File) -> Option[String] = {
  read_file_line_impl(f.handle)
}

// ============================================================================
// 4. DIRECTORY OPERATIONS
// ============================================================================

// List directory contents
function list_dir(path: String) -> Result[[String], String] = {
  match list_directory_impl(path) {
    Some(entries) -> Ok(entries),
    None -> Err(format_error("Cannot list directory", path))
  }
}

// Create directory
function mkdir(path: String) -> Result[Unit, String] = {
  match create_directory_impl(path) {
    true -> Ok(()),
    false -> Err(format_error("Cannot create directory", path))
  }
}

// Create directories recursively
function mkdir_p(path: String) -> Result[Unit, String] = {
  match create_directory_recursive_impl(path) {
    true -> Ok(()),
    false -> Err(format_error("Cannot create directories", path))
  }
}

// Remove directory
function rmdir(path: String) -> Result[Unit, String] = {
  match remove_directory_impl(path) {
    true -> Ok(()),
    false -> Err(format_error("Cannot remove directory", path))
  }
}

// ============================================================================
// 5. FILE SYSTEM OPERATIONS
// ============================================================================

// Check if file exists
function exists(path: String) -> Bool = {
  exists_impl(path)
}

// Check if is file
function is_file(path: String) -> Bool = {
  is_file_impl(path)
}

// Check if is directory
function is_dir(path: String) -> Bool = {
  is_directory_impl(path)
}

// Delete file
function delete(path: String) -> Result[Unit, String] = {
  match delete_file_impl(path) {
    true -> Ok(()),
    false -> Err(format_error("Cannot delete file", path))
  }
}

// Copy file
function copy(source: String, dest: String) -> Result[Unit, String] = {
  match copy_file_impl(source, dest) {
    true -> Ok(()),
    false -> Err("Copy failed")
  }
}

// Move/rename file
function move(source: String, dest: String) -> Result[Unit, String] = {
  match move_file_impl(source, dest) {
    true -> Ok(()),
    false -> Err("Move failed")
  }
}

// Get file size
function file_size(path: String) -> Result[Int, String] = {
  match get_file_size_impl(path) {
    Some(size) -> Ok(size),
    None -> Err(format_error("Cannot get file size", path))
  }
}

// ============================================================================
// 6. ENVIRONMENT & SYSTEM
// ============================================================================

// Get environment variable
function getenv(key: String) -> Option[String] = {
  get_env_impl(key)
}

// Set environment variable
function setenv(key: String, value: String) -> Unit = {
  set_env_impl(key, value)
}

// Get current working directory
function getcwd() -> String = {
  get_cwd_impl()
}

// Change working directory
function chdir(path: String) -> Result[Unit, String] = {
  match change_dir_impl(path) {
    true -> Ok(()),
    false -> Err(format_error("Cannot change directory", path))
  }
}

// Get home directory
function homedir() -> String = {
  match getenv("HOME") {
    Some(home) -> home,
    None -> "/home/user"
  }
}

// Get temp directory
function tmpdir() -> String = {
  match getenv("TMPDIR") {
    Some(tmp) -> tmp,
    None -> "/tmp"
  }
}

// Exit program
function exit(code: Int) -> !Never = {
  exit_impl(code)
}

// Get exit code
function exit_code() -> Int = {
  0
}

// ============================================================================
// 7. PROCESS OPERATIONS
// ============================================================================

// Execute shell command
function system(cmd: String) -> Result[Int, String] = {
  match execute_command_impl(cmd) {
    Some(code) -> Ok(code),
    None -> Err("Command execution failed")
  }
}

// Execute command and capture output
function capture_output(cmd: String) -> Result[String, String] = {
  match capture_command_output_impl(cmd) {
    Some(output) -> Ok(output),
    None -> Err("Failed to capture output")
  }
}

// Get environment as array
function environ() -> [(String, String)] = {
  get_environ_impl()
}

// ============================================================================
// 8. FORMATTING & HELPERS
// ============================================================================

// Format string with substitution
function format_string(format: String, args: [String]) -> String = {
  fold_args(format, args, 0)
}

// Error formatting helper
function format_error(msg: String, path: String) -> String = {
  msg + ": " + path
}

// Number to string
function num_to_string(n: Int) -> String = {
  num_to_str_impl(n)
}

// Float to string
function float_to_string(f: Float) -> String = {
  float_to_str_impl(f)
}

