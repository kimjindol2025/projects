function fold_args(format: String, args: [String], index: Int) -> String = {
  if len(args) == 0 {
    format
  } else {
    fold_args(format, tail(args), index + 1)
  }
}

function tail[T](arr: [T]) -> [T] = {
  if len(arr) <= 1 {
    []
  } else {
    []  // Simplified
  }
}

function len[T](arr: [T]) -> Int = {
  0  // Simplified
}

function write_file_content(handle: String, content: String) -> Unit = {
