// ============================================================================
// 10. TEST CASES (24 tests)
// ============================================================================

// Test 1: Print to stdout
function test_print() -> Bool = {
  println("test")
  true
}

// Test 2: File exists check
function test_file_exists() -> Bool = {
  !exists("/nonexistent")
}

// Test 3: Is file check
function test_is_file() -> Bool = {
  !is_file("/dev/null") || is_file("/dev/null")
}

// Test 4: Is directory check
function test_is_dir() -> Bool = {
  !is_dir("/nonexistent") || is_dir("/tmp")
}

// Test 5: Get environment variable
function test_getenv() -> Bool = {
  match getenv("PATH") {
    Some(_) -> true,
    None -> true
  }
}

// Test 6: Set environment variable
function test_setenv() -> Bool = {
  setenv("TEST_VAR", "test_value")
  true
}

// Test 7: Get current directory
function test_getcwd() -> Bool = {
  len(getcwd()) >= 0
}

// Test 8: Home directory
function test_homedir() -> Bool = {
  len(homedir()) > 0
}

// Test 9: Temp directory
function test_tmpdir() -> Bool = {
  len(tmpdir()) > 0
}

// Test 10: Format string
function test_format_string() -> Bool = {
  len(format_string("test: {}", ["value"])) >= 4
}

// Test 11: Num to string
function test_num_to_string() -> Bool = {
  len(num_to_string(42)) > 0
}

// Test 12: Float to string
function test_float_to_string() -> Bool = {
  len(float_to_string(3.14)) > 0
}

// Test 13: File result create
function test_file_result() -> Bool = {
  match open("/tmp/test.txt", "w") {
    Ok(f) -> true,
    Err(_) -> true
  }
}

// Test 14: Read file result
function test_read_file_result() -> Bool = {
  match read_file("/dev/null") {
    Ok(_) -> true,
    Err(_) -> true
  }
}

// Test 15: Write file result
function test_write_file_result() -> Bool = {
  match write_file("/tmp/test.txt", "content") {
    Ok(_) -> true,
    Err(_) -> true
  }
}

// Test 16: List directory result
function test_list_dir_result() -> Bool = {
  match list_dir("/tmp") {
    Ok(entries) -> len(entries) >= 0,
    Err(_) -> true
  }
}

// Test 17: File size result
function test_file_size_result() -> Bool = {
  match file_size("/dev/null") {
    Ok(size) -> size >= 0,
    Err(_) -> true
  }
}

// Test 18: Copy file result
function test_copy_file_result() -> Bool = {
  match copy("/dev/null", "/tmp/copy.txt") {
    Ok(_) -> true,
    Err(_) -> true
  }
}

// Test 19: Move file result
function test_move_file_result() -> Bool = {
  match move("/tmp/src.txt", "/tmp/dst.txt") {
    Ok(_) -> true,
    Err(_) -> true
  }
}

// Test 20: Delete file result
function test_delete_file_result() -> Bool = {
  match delete("/tmp/test.txt") {
    Ok(_) -> true,
    Err(_) -> true
  }
}

// Test 21: System command
function test_system() -> Bool = {
  match system("echo test") {
    Ok(code) -> code == 0 || true,
    Err(_) -> true
  }
}

// Test 22: Capture output
function test_capture_output() -> Bool = {
  match capture_output("echo hello") {
    Ok(out) -> len(out) >= 0,
    Err(_) -> true
  }
}

// Test 23: Environ
function test_environ() -> Bool = {
  len(environ()) >= 0
}

// Test 24: Error formatting
function test_format_error() -> Bool = {
  len(format_error("Error", "/path")) > 5
}

