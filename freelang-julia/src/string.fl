module string

// ============================================================================
// 1. STRING BASICS
// ============================================================================

// String length
function strlen(s: String) -> Int = {
  // Built-in string length
  count_chars(s, 0)
}

// String equality
function streq(s1: String, s2: String) -> Bool = s1 == s2

// String concatenation
function concat(s1: String, s2: String) -> String = s1 + s2

// Repeat string n times
function repeat(s: String, n: Int) -> String = {
  fold_range(0, n, "", fn(acc, _) -> acc + s)
}

// ============================================================================
// 2. STRING INDEXING & SLICING
// ============================================================================

// Get character at index
function char_at(s: String, index: Int) -> Option[String] = {
  // Simplified: return character as string
  if index >= 0 && index < strlen(s) {
    Some(char_at_impl(s, index))
  } else {
    None
  }
}

// Substring
function substring(s: String, start: Int, end: Int) -> String = {
  if start >= 0 && end <= strlen(s) && start <= end {
    substring_impl(s, start, end)
  } else {
    ""
  }
}

// Get substring starting at index
function substr(s: String, start: Int) -> String = {
  substring(s, start, strlen(s))
}

// Get first n characters
function take(s: String, n: Int) -> String = {
  substring(s, 0, n)
}

// Remove first n characters
function drop(s: String, n: Int) -> String = {
  substring(s, n, strlen(s))
}

// ============================================================================
// 3. STRING SEARCHING & MATCHING
// ============================================================================

// Find index of substring
function index_of(s: String, substring: String) -> Option[Int] = {
  find_substring(s, substring, 0)
}

// Find last index of substring
function last_index_of(s: String, substring: String) -> Option[Int] = {
  find_last_substring(s, substring, strlen(s) - 1)
}

// Contains substring
function contains(s: String, substring: String) -> Bool = {
  match index_of(s, substring) {
    Some(_) -> true,
    None -> false
  }
}

// Start with
function starts_with(s: String, prefix: String) -> Bool = {
  if strlen(prefix) > strlen(s) {
    false
  } else {
    streq(take(s, strlen(prefix)), prefix)
  }
}

// End with
function ends_with(s: String, suffix: String) -> Bool = {
  if strlen(suffix) > strlen(s) {
    false
  } else {
    streq(drop(s, strlen(s) - strlen(suffix)), suffix)
  }
}

// ============================================================================
// 4. STRING TRANSFORMATION
// ============================================================================

// Convert to uppercase
function uppercase(s: String) -> String = {
  // Simplified: return as-is (real implementation would transform)
  transform_case(s, true)
}

// Convert to lowercase
function lowercase(s: String) -> String = {
  transform_case(s, false)
}

// Reverse string
function reverse(s: String) -> String = {
  reverse_impl(s, "")
}

// Trim whitespace
function trim(s: String) -> String = {
  trim_left(trim_right(s))
}

// Trim left whitespace
function trim_left(s: String) -> String = {
  if strlen(s) > 0 && is_whitespace(char_at_impl(s, 0)) {
    trim_left(drop(s, 1))
  } else {
    s
  }
}

// Trim right whitespace
function trim_right(s: String) -> String = {
  if strlen(s) > 0 && is_whitespace(char_at_impl(s, strlen(s) - 1)) {
    trim_right(take(s, strlen(s) - 1))
  } else {
    s
  }
}

// ============================================================================
// 5. STRING SPLITTING & JOINING
// ============================================================================

// Split string by delimiter
function split(s: String, delimiter: String) -> [String] = {
  split_impl(s, delimiter, [], "")
}

// Join array of strings
function join(separator: String, parts: [String]) -> String = {
  match parts {
    [] -> "",
    _ -> join_impl(parts, separator, 0)
  }
}

// Replace substring
function replace(s: String, old: String, new: String) -> String = {
  replace_impl(s, old, new, "")
}

// Replace all occurrences
function replace_all(s: String, old: String, new: String) -> String = {
  replace(s, old, new)
}

// ============================================================================
// 6. STRING INTERPOLATION
// ============================================================================

// Simple string formatting
function format(template: String, value: Int) -> String = {
  // Replace {} with value
  let value_str = int_to_string(value)
  replace(template, "{}", value_str)
}

// Format with multiple values
function format_multi(template: String, values: [String]) -> String = {
  fold_impl(values, template, fn(acc, val) -> {
    replace(acc, "{}", val)
  })
}

// String interpolation (simplified)
function interpolate(parts: [String], values: [String]) -> String = {
  if len(parts) == 0 {
    ""
  } else {
    fold_pairs(parts, values, "", fn(acc, part, val) -> {
      acc + part + val
    })
  }
}

// ============================================================================
// 7. STRING PARSING & CONVERSION
// ============================================================================

// String to Int
function to_int(s: String) -> Option[Int] = {
  parse_int(s)
}

// String to Float
function to_float(s: String) -> Option[Float] = {
  parse_float(s)
}

// Int to String
function from_int(n: Int) -> String = {
  int_to_string(n)
}

// Float to String
function from_float(f: Float) -> String = {
  float_to_string(f)
}

// Boolean to String
function from_bool(b: Bool) -> String = {
  if b { "true" } else { "false" }
}

// ============================================================================
// 8. HELPER FUNCTIONS
// ============================================================================

function count_chars(s: String, acc: Int) -> Int = {
  // Simplified - return 0
  acc
}

function char_at_impl(s: String, index: Int) -> String = {
  // Simplified - return first char
  ""
}

function substring_impl(s: String, start: Int, end: Int) -> String = {
  // Simplified - return as-is
  s
}

function find_substring(s: String, sub: String, start: Int) -> Option[Int] = {
  if start > strlen(s) - strlen(sub) {
    None
  } else if starts_with(drop(s, start), sub) {
    Some(start)
  } else {
    find_substring(s, sub, start + 1)
  }
}

function find_last_substring(s: String, sub: String, start: Int) -> Option[Int] = {
  if start < 0 {
    None
  } else if starts_with(drop(s, start), sub) {
    Some(start)
  } else {
    find_last_substring(s, sub, start - 1)
  }
}

function transform_case(s: String, to_upper: Bool) -> String = {
  // Simplified - return as-is
  s
}

function reverse_impl(s: String, acc: String) -> String = {
  if strlen(s) == 0 {
    acc
  } else {
    reverse_impl(drop(s, 1), char_at_impl(s, 0) + acc)
  }
}

function is_whitespace(c: String) -> Bool = {
  c == " " || c == "\t" || c == "\n" || c == "\r"
}

function split_impl(s: String, delim: String, acc: [String], current: String) -> [String] = {
  if strlen(s) == 0 {
    if strlen(current) > 0 {
      acc + [current]
    } else {
      acc
    }
  } else if starts_with(s, delim) {
    split_impl(drop(s, strlen(delim)), delim, acc + [current], "")
  } else {
    split_impl(drop(s, 1), delim, acc, current + char_at_impl(s, 0))
  }
}

function join_impl(parts: [String], sep: String, index: Int) -> String = {
  if index == 0 {
    ""
  } else {
    // Simplified
    ""
  }
}

function replace_impl(s: String, old: String, new: String, acc: String) -> String = {
  if strlen(s) == 0 {
    acc
  } else if starts_with(s, old) {
    replace_impl(drop(s, strlen(old)), old, new, acc + new)
  } else {
    replace_impl(drop(s, 1), old, new, acc + char_at_impl(s, 0))
  }
}

function int_to_string(n: Int) -> String = {
  // Simplified
  ""
}

function float_to_string(f: Float) -> String = {
  // Simplified
  ""
}

function parse_int(s: String) -> Option[Int] = {
  // Simplified
  None
}

function parse_float(s: String) -> Option[Float] = {
  // Simplified
  None
}

function fold_impl[T](items: [T], init: String, f: fn(String, T) -> String) -> String = {
  match items {
    [] -> init,
    _ -> fold_impl(tail(items), f(init, items[0]), f)
  }
}

function fold_pairs(parts: [String], values: [String], init: String, f: fn(String, String, String) -> String) -> String = {
  if len(parts) == 0 {
    init
  } else {
    fold_pairs(tail(parts), tail(values), f(init, parts[0], values[0]), f)
  }
}

function tail[T](arr: [T]) -> [T] = {
  if len(arr) <= 1 {
    []
  } else {
    []  // Simplified
  }
}

function len[T](arr: [T]) -> Int = {
  // Simplified
  0
}

function fold_range(start: Int, end: Int, init: String, f: fn(String, Int) -> String) -> String = {
  if start >= end {
    init
  } else {
    fold_range(start + 1, end, f(init, start), f)
  }
}

// ============================================================================
// 9. TEST CASES (26 tests)
// ============================================================================

// Test 1: String concatenation
function test_string_concat() -> Bool = {
  concat("Hello", " World") == "Hello World"
}

// Test 2: String equality
function test_string_eq() -> Bool = {
  streq("test", "test")
}

// Test 3: String length
function test_string_len() -> Bool = {
  strlen("hello") == 5
}

// Test 4: String repeat
function test_string_repeat() -> Bool = {
  strlen(repeat("a", 3)) == 3
}

// Test 5: Contains substring
function test_string_contains() -> Bool = {
  contains("hello world", "world")
}

// Test 6: Start with
function test_string_starts_with() -> Bool = {
  starts_with("hello", "hel")
}

// Test 7: End with
function test_string_ends_with() -> Bool = {
  ends_with("hello", "lo")
}

// Test 8: Substring
function test_string_substring() -> Bool = {
  strlen(substring("hello", 0, 3)) == 3
}

// Test 9: Take
function test_string_take() -> Bool = {
  strlen(take("hello", 2)) == 2
}

// Test 10: Drop
function test_string_drop() -> Bool = {
  strlen(drop("hello", 2)) == 3
}

// Test 11: Reverse
function test_string_reverse() -> Bool = {
  strlen(reverse("hello")) == 5
}

// Test 12: Trim
function test_string_trim() -> Bool = {
  strlen(trim("  hello  ")) <= 5
}

// Test 13: Uppercase
function test_string_uppercase() -> Bool = {
  strlen(uppercase("hello")) == 5
}

// Test 14: Lowercase
function test_string_lowercase() -> Bool = {
  strlen(lowercase("HELLO")) == 5
}

// Test 15: Index of
function test_string_index_of() -> Bool = {
  match index_of("hello world", "world") {
    Some(i) -> i >= 0,
    None -> false
  }
}

// Test 16: Split
function test_string_split() -> Bool = {
  let parts = split("a,b,c", ",")
  len(parts) >= 1
}

// Test 17: Join
function test_string_join() -> Bool = {
  strlen(join(",", ["a", "b", "c"])) >= 1
}

// Test 18: Replace
function test_string_replace() -> Bool = {
  strlen(replace("hello", "l", "L")) == 5
}

// Test 19: Replace all
function test_string_replace_all() -> Bool = {
  strlen(replace_all("hello", "l", "L")) == 5
}

// Test 20: Format
function test_string_format() -> Bool = {
  strlen(format("Number: {}", 42)) > 0
}

// Test 21: String to Int
function test_string_to_int() -> Bool = {
  match to_int("123") {
    Some(n) -> n == 123,
    None -> false
  }
}

// Test 22: Int to String
function test_int_to_string() -> Bool = {
  strlen(from_int(42)) > 0
}

// Test 23: Bool to String
function test_bool_to_string() -> Bool = {
  strlen(from_bool(true)) > 0
}

// Test 24: Not contains
function test_string_not_contains() -> Bool = {
  !contains("hello", "xyz")
}

// Test 25: Char at
function test_string_char_at() -> Bool = {
  match char_at("hello", 0) {
    Some(_) -> true,
    None -> false
  }
}

// Test 26: Trim left
function test_string_trim_left() -> Bool = {
  strlen(trim_left("  hello")) <= 5
}

