# ==========================================
# Phase D Task D.2: Parser Bootstrap 테스트
# (15개 테스트 케이스)
# ==========================================

# Test 1: 함수 정의 파싱
function test_parse_function(): Bool =
  let tokens = tokenize("fn add(a: Int, b: Int): Int = a + b")
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "function" &&
  ast.children[0].name == "add"

# Test 2: 구조체 정의 파싱
function test_parse_struct(): Bool =
  let tokens = tokenize("struct Point { x: Float, y: Float }")
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "struct" &&
  ast.children[0].name == "Point"

# Test 3: record 정의 파싱
function test_parse_record(): Bool =
  let tokens = tokenize("record Person = name: String, age: Int")
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "record"

# Test 4: let 바인딩 파싱
function test_parse_let(): Bool =
  let tokens = tokenize("let x: Int = 42")
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "let" &&
  ast.children[0].name == "x"

# Test 5: if 문 파싱
function test_parse_if(): Bool =
  let tokens = tokenize("if x > 0 then let y = 1")
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "if"

# Test 6: for 루프 파싱
function test_parse_for(): Bool =
  let tokens = tokenize("for i in 1:10 do let x = i")
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "for" &&
  ast.children[0].name == "i"

# Test 7: enum 정의 파싱
function test_parse_enum(): Bool =
  let tokens = tokenize("enum Color = Red | Green | Blue")
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "enum"

# Test 8: match 표현식 파싱
function test_parse_match(): Bool =
  let tokens = tokenize("match x { Some(v) -> v, None -> 0 }")
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "match"

# Test 9: 이항 연산 파싱
function test_parse_binary_op(): Bool =
  let tokens = tokenize("2 + 3 * 4")
  let ast = parse(tokens)
  ast.type == "program" &&
  ast.children.length() >= 1

# Test 10: 단항 연산 파싱
function test_parse_unary_op(): Bool =
  let tokens = tokenize("-x")
  let ast = parse(tokens)
  ast.type == "program"

# Test 11: 함수 호출 파싱
function test_parse_function_call(): Bool =
  let tokens = tokenize("add(2, 3)")
  let ast = parse(tokens)
  ast.type == "program" &&
  ast.children.length() >= 1

# Test 12: 배열 인덱싱 파싱
function test_parse_array_indexing(): Bool =
  let tokens = tokenize("arr[0]")
  let ast = parse(tokens)
  ast.type == "program"

# Test 13: 멤버 접근 파싱
function test_parse_member_access(): Bool =
  let tokens = tokenize("point.x")
  let ast = parse(tokens)
  ast.type == "program"

# Test 14: return 문 파싱
function test_parse_return(): Bool =
  let tokens = tokenize("return 42")
  let ast = parse(tokens)
  ast.type == "program" &&
  ast.children.length() >= 1

# Test 15: 복합 프로그램 파싱
function test_parse_complex_program(): Bool =
  let tokens = tokenize(
    "fn fibonacci(n: Int): Int = " +
    "if n <= 1 then n else fibonacci(n - 1) + fibonacci(n - 2)"
  )
  let ast = parse(tokens)
  ast.type == "program" && ast.children.length() >= 1 &&
  ast.children[0].type == "function" &&
  ast.children[0].name == "fibonacci"

# ==========================================
# 테스트 실행
# ==========================================

function main(): Unit =
  let tests = [
    ("test_parse_function", test_parse_function()),
    ("test_parse_struct", test_parse_struct()),
    ("test_parse_record", test_parse_record()),
    ("test_parse_let", test_parse_let()),
    ("test_parse_if", test_parse_if()),
    ("test_parse_for", test_parse_for()),
    ("test_parse_enum", test_parse_enum()),
    ("test_parse_match", test_parse_match()),
    ("test_parse_binary_op", test_parse_binary_op()),
    ("test_parse_unary_op", test_parse_unary_op()),
    ("test_parse_function_call", test_parse_function_call()),
    ("test_parse_array_indexing", test_parse_array_indexing()),
    ("test_parse_member_access", test_parse_member_access()),
    ("test_parse_return", test_parse_return()),
    ("test_parse_complex_program", test_parse_complex_program())
  ]

  let passed = 0
  let failed = 0

  for (name, result) in tests do
    if result then
      println("[✓] " + name)
      passed = passed + 1
    else
      println("[✗] " + name)
      failed = failed + 1
    end
  end

  println("\n==========================================")
  println("Parser Bootstrap Test Result:")
  println("Passed: " + passed.to_string())
  println("Failed: " + failed.to_string())
  println("Total:  " + (passed + failed).to_string())
  println("==========================================")
