// FV 2.0 Self-Hosting: Type Checker를 FV 언어로 재작성
// 목표: FV를 FV로 타입 검사

// ============= Type 정의 =============

enum BaseType {
	Primitive
	Array
	Function
	Option
	Result
	Struct
	Union
	Dynamic
	Protocol
}

struct VType {
	mut base_type: BaseType
	mut name: string
	mut element_type: ?VType
	mut param_types: []VType
	mut return_type: ?VType
	mut fields: map[string]VType
	mut variants: []string
}

struct TypeCheckError {
	mut message: string
	mut line: i32
	mut column: i32
	mut kind: string
}

// ============= TypeChecker 구조체 =============

struct TypeChecker {
	mut variables: map[string]VType
	mut functions: map[string]VType
	mut structs: map[string]VType
	mut errors: []TypeCheckError
	mut current_function: ?string
}

// ============= 초기화 =============

fn new_type_checker() TypeChecker {
	return TypeChecker{
		variables: map[string]VType{},
		functions: map[string]VType{},
		structs: map[string]VType{},
		errors: [],
		current_function: none
	}
}

// ============= 타입 생성 헬퍼 =============

fn primitive_type(name: string) VType {
	return VType{
		base_type: BaseType.Primitive,
		name: name,
		element_type: none,
		param_types: [],
		return_type: none,
		fields: map[string]VType{},
		variants: []
	}
}

fn array_type(element_type: VType) VType {
	return VType{
		base_type: BaseType.Array,
		name: "array",
		element_type: element_type,
		param_types: [],
		return_type: none,
		fields: map[string]VType{},
		variants: []
	}
}

fn option_type(inner_type: VType) VType {
	return VType{
		base_type: BaseType.Option,
		name: "option",
		element_type: inner_type,
		param_types: [],
		return_type: none,
		fields: map[string]VType{},
		variants: []
	}
}

fn result_type(ok_type: VType, err_type: VType) VType {
	return VType{
		base_type: BaseType.Result,
		name: "result",
		element_type: ok_type,
		param_types: [err_type],
		return_type: none,
		fields: map[string]VType{},
		variants: []
	}
}

fn function_type(param_types: []VType, return_type: VType) VType {
	return VType{
		base_type: BaseType.Function,
		name: "function",
		element_type: none,
		param_types: param_types,
		return_type: return_type,
		fields: map[string]VType{},
		variants: []
	}
}

fn struct_type(name: string, fields: map[string]VType) VType {
	return VType{
		base_type: BaseType.Struct,
		name: name,
		element_type: none,
		param_types: [],
		return_type: none,
		fields: fields,
		variants: []
	}
}

// ============= 기본 타입 등록 =============

fn (mut tc: TypeChecker) register_builtin_types() {
	tc.variables["i32"] = primitive_type("i32")
	tc.variables["i64"] = primitive_type("i64")
	tc.variables["f32"] = primitive_type("f32")
	tc.variables["f64"] = primitive_type("f64")
	tc.variables["bool"] = primitive_type("bool")
	tc.variables["string"] = primitive_type("string")
	tc.variables["void"] = primitive_type("void")
	tc.variables["byte"] = primitive_type("byte")
	tc.variables["rune"] = primitive_type("rune")
}

// ============= 에러 처리 =============

fn (mut tc: TypeChecker) add_error(message: string, line: i32, column: i32, kind: string) {
	tc.errors.push(TypeCheckError{
		message: message,
		line: line,
		column: column,
		kind: kind
	})
}

fn (tc: TypeChecker) has_errors() bool {
	return tc.errors.len() > 0
}

// ============= 타입 비교 =============

fn types_equal(t1: VType, t2: VType) bool {
	if t1.base_type != t2.base_type {
		return false
	}

	match t1.base_type {
		BaseType.Primitive => {
			return t1.name == t2.name
		}
		BaseType.Array => {
			if let Some(e1) = t1.element_type {
				if let Some(e2) = t2.element_type {
					return types_equal(e1, e2)
				}
			}
			return false
		}
		BaseType.Option => {
			if let Some(e1) = t1.element_type {
				if let Some(e2) = t2.element_type {
					return types_equal(e1, e2)
				}
			}
			return false
		}
		BaseType.Function => {
			if t1.param_types.len() != t2.param_types.len() {
				return false
			}

			for i in 0..t1.param_types.len() {
				if !types_equal(t1.param_types[i], t2.param_types[i]) {
					return false
				}
			}

			if let Some(r1) = t1.return_type {
				if let Some(r2) = t2.return_type {
					return types_equal(r1, r2)
				}
			}
			return false
		}
		BaseType.Struct => {
			return t1.name == t2.name
		}
		_ => {
			return t1.name == t2.name
		}
	}
}

// ============= 타입 호환성 =============

fn is_type_compatible(actual: VType, expected: VType) bool {
	if types_equal(actual, expected) {
		return true
	}

	if expected.name == "any" {
		return true
	}

	if let BaseType.Option = expected.base_type {
		if let Some(inner) = expected.element_type {
			return is_type_compatible(actual, inner)
		}
	}

	if let BaseType.Result = expected.base_type {
		if let Some(ok_type) = expected.element_type {
			return is_type_compatible(actual, ok_type)
		}
	}

	return false
}

// ============= 변수 등록 & 조회 =============

fn (mut tc: TypeChecker) register_variable(name: string, var_type: VType) {
	tc.variables[name] = var_type
}

fn (mut tc: TypeChecker) register_function(name: string, func_type: VType) {
	tc.functions[name] = func_type
}

fn (mut tc: TypeChecker) register_struct(name: string, struct_type: VType) {
	tc.structs[name] = struct_type
}

fn (tc: TypeChecker) lookup_variable(name: string) ?VType {
	if name in tc.variables {
		return tc.variables[name]
	}
	return none
}

fn (tc: TypeChecker) lookup_function(name: string) ?VType {
	if name in tc.functions {
		return tc.functions[name]
	}
	return none
}

fn (tc: TypeChecker) lookup_struct(name: string) ?VType {
	if name in tc.structs {
		return tc.structs[name]
	}
	return none
}

// ============= 식 검사 =============

fn (mut tc: TypeChecker) check_identifier(name: string, line: i32, column: i32) ?VType {
	if let Some(var_type) = tc.lookup_variable(name) {
		return var_type
	}

	if let Some(func_type) = tc.lookup_function(name) {
		return func_type
	}

	if let Some(struct_type) = tc.lookup_struct(name) {
		return struct_type
	}

	tc.add_error("undefined variable or function: '${name}'", line, column, "undefined_identifier")
	return none
}

fn (mut tc: TypeChecker) check_int_literal(value: string) VType {
	return primitive_type("i64")
}

fn (mut tc: TypeChecker) check_float_literal(value: string) VType {
	return primitive_type("f64")
}

fn (mut tc: TypeChecker) check_string_literal(value: string) VType {
	return primitive_type("string")
}

fn (mut tc: TypeChecker) check_bool_literal(value: string) VType {
	return primitive_type("bool")
}

// ============= 이항 연산 검사 =============

fn (mut tc: TypeChecker) check_binary_op(
	left_type: VType,
	operator: string,
	right_type: VType,
	line: i32,
	column: i32
) ?VType {
	if !types_equal(left_type, right_type) {
		tc.add_error(
			"type mismatch in binary operation: '${left_type.name}' ${operator} '${right_type.name}'",
			line,
			column,
			"type_mismatch"
		)
		return none
	}

	// 산술 연산자
	if operator in ["+", "-", "*", "/", "%"] {
		match left_type.name {
			"i32", "i64", "f32", "f64" => {
				return left_type
			}
			"string" => {
				if operator == "+" {
					return left_type
				}
			}
			_ => {
				tc.add_error(
					"${operator} not supported for type '${left_type.name}'",
					line,
					column,
					"unsupported_operation"
				)
				return none
			}
		}
	}

	// 비교 연산자
	if operator in ["==", "!=", "<", ">", "<=", ">="] {
		return primitive_type("bool")
	}

	// 논리 연산자
	if operator in ["&&", "||"] {
		if left_type.name != "bool" {
			tc.add_error(
				"logical operator requires bool type, got '${left_type.name}'",
				line,
				column,
				"type_error"
			)
			return none
		}
		return primitive_type("bool")
	}

	tc.add_error("unknown operator: '${operator}'", line, column, "unknown_operator")
	return none
}

// ============= 단항 연산 검사 =============

fn (mut tc: TypeChecker) check_unary_op(
	operator: string,
	operand_type: VType,
	line: i32,
	column: i32
) ?VType {
	match operator {
		"-" => {
			if operand_type.name in ["i32", "i64", "f32", "f64"] {
				return operand_type
			}
			tc.add_error(
				"unary minus requires numeric type, got '${operand_type.name}'",
				line,
				column,
				"type_error"
			)
			return none
		}
		"!" => {
			if operand_type.name == "bool" {
				return operand_type
			}
			tc.add_error(
				"logical not requires bool type, got '${operand_type.name}'",
				line,
				column,
				"type_error"
			)
			return none
		}
		_ => {
			tc.add_error("unknown unary operator: '${operator}'", line, column, "unknown_operator")
			return none
		}
	}
}

// ============= 함수 호출 검사 =============

fn (mut tc: TypeChecker) check_function_call(
	func_name: string,
	arg_types: []VType,
	line: i32,
	column: i32
) ?VType {
	if let Some(func_type) = tc.lookup_function(func_name) {
		if let BaseType.Function = func_type.base_type {
			if arg_types.len() != func_type.param_types.len() {
				tc.add_error(
					"function '${func_name}' expects ${func_type.param_types.len()} arguments, got ${arg_types.len()}",
					line,
					column,
					"arity_mismatch"
				)
				return none
			}

			for i in 0..arg_types.len() {
				if !is_type_compatible(arg_types[i], func_type.param_types[i]) {
					tc.add_error(
						"argument ${i} type mismatch: expected '${func_type.param_types[i].name}', got '${arg_types[i].name}'",
						line,
						column,
						"type_mismatch"
					)
					return none
				}
			}

			return func_type.return_type
		}
	}

	tc.add_error("undefined function: '${func_name}'", line, column, "undefined_function")
	return none
}

// ============= 배열 인덱싱 검사 =============

fn (mut tc: TypeChecker) check_array_indexing(
	array_type: VType,
	index_type: VType,
	line: i32,
	column: i32
) ?VType {
	if let BaseType.Array = array_type.base_type {
		if index_type.name not in ["i32", "i64"] {
			tc.add_error(
				"array index must be integer type, got '${index_type.name}'",
				line,
				column,
				"type_error"
			)
			return none
		}

		return array_type.element_type
	}

	tc.add_error(
		"cannot index non-array type '${array_type.name}'",
		line,
		column,
		"type_error"
	)
	return none
}

// ============= 필드 접근 검사 =============

fn (mut tc: TypeChecker) check_field_access(
	object_type: VType,
	field_name: string,
	line: i32,
	column: i32
) ?VType {
	if let BaseType.Struct = object_type.base_type {
		if field_name in object_type.fields {
			return object_type.fields[field_name]
		}

		tc.add_error(
			"struct '${object_type.name}' has no field '${field_name}'",
			line,
			column,
			"field_not_found"
		)
		return none
	}

	tc.add_error(
		"cannot access field on non-struct type '${object_type.name}'",
		line,
		column,
		"type_error"
	)
	return none
}

// ============= 문 검사 =============

fn (mut tc: TypeChecker) check_let_statement(
	name: string,
	declared_type: ?VType,
	init_type: VType,
	line: i32,
	column: i32
) bool {
	if let Some(dtype) = declared_type {
		if !is_type_compatible(init_type, dtype) {
			tc.add_error(
				"type mismatch: variable '${name}' declared as '${dtype.name}', initialized with '${init_type.name}'",
				line,
				column,
				"type_mismatch"
			)
			return false
		}
		tc.register_variable(name, dtype)
	} else {
		tc.register_variable(name, init_type)
	}

	return true
}

fn (mut tc: TypeChecker) check_function_def(
	name: string,
	param_types: []VType,
	return_type: VType,
	line: i32,
	column: i32
) bool {
	let func_type = function_type(param_types, return_type)
	tc.register_function(name, func_type)
	tc.current_function = name
	return true
}

fn (mut tc: TypeChecker) check_return_statement(
	return_type: ?VType,
	expected_return_type: VType,
	line: i32,
	column: i32
) bool {
	if let Some(rtype) = return_type {
		if !is_type_compatible(rtype, expected_return_type) {
			tc.add_error(
				"return type mismatch: expected '${expected_return_type.name}', got '${rtype.name}'",
				line,
				column,
				"return_type_mismatch"
			)
			return false
		}
	} else if expected_return_type.name != "void" {
		tc.add_error(
			"function expects return value of type '${expected_return_type.name}'",
			line,
			column,
			"missing_return_value"
		)
		return false
	}

	return true
}

fn (mut tc: TypeChecker) check_if_statement(
	condition_type: VType,
	line: i32,
	column: i32
) bool {
	if condition_type.name != "bool" {
		tc.add_error(
			"if condition must be bool type, got '${condition_type.name}'",
			line,
			column,
			"type_error"
		)
		return false
	}

	return true
}

fn (mut tc: TypeChecker) check_for_statement(
	iterator_type: VType,
	line: i32,
	column: i32
) bool {
	if let BaseType.Array = iterator_type.base_type {
		return true
	}

	if iterator_type.base_type == BaseType.Protocol {
		return true
	}

	tc.add_error(
		"for loop requires array or iterable type, got '${iterator_type.name}'",
		line,
		column,
		"type_error"
	)
	return false
}

// ============= 메인 Type Checking =============

fn (mut tc: TypeChecker) check() bool {
	tc.register_builtin_types()
	return !tc.has_errors()
}

// ============= 진단 함수 =============

fn (tc: TypeChecker) get_errors() []TypeCheckError {
	return tc.errors
}

fn (tc: TypeChecker) print_errors() {
	for error in tc.errors {
		println("Error at ${error.line}:${error.column} [${error.kind}]: ${error.message}")
	}
}
