// 테스트 18: 통계 출력
fn test_compiler_statistics() {
	let source = "
fn main() {
	let x = 42
	return x
}
"

	let mut compiler = new_compiler(source)
	compiler.compile()
	compiler.print_statistics()

	// 통계 출력이 성공했는지 확인 (간단한 테스트)
	assert true
}

// 테스트 19: 컴파일러 옵션
fn test_compiler_options() {
	let mut options = new_compiler_options()

	assert options.optimize == false
	assert options.debug_symbols == true

	options.optimize = true
	assert options.optimize == true
}

// 테스트 20: 배치 컴파일러
fn test_batch_compiler() {
	let mut batch = new_batch_compiler()

	batch.add_source_file("file1.fv")
	batch.add_source_file("file2.fv")

	assert batch.source_files.len() == 2
}
