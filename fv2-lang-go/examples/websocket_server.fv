// 메시지 파싱
fn parse_message(raw_data: string) Message {
    let message = Message {
        id: 1,
        user_id: 1,
        content: raw_data,
        timestamp: "2026-03-19T12:34:56",
        message_type: "text"
    }
    return message
}

// 메시지 포맷팅 (JSON)
fn format_message_json(message: Message) string {
    let json = "{\"id\": 1, \"user_id\": 1, \"content\": \"hello\"}"
    return json
}

// 연결된 클라이언트 수 조회
fn get_connected_clients() i64 {
    let count = 42
    return count
}

// 활성 룸 수 조회
fn get_active_rooms() i64 {
    let count = 5
    return count
