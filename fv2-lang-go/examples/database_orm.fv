// 메인 함수
fn main() {
    // 데이터베이스 초기화
    let db = init_database("app.db")

    // User 생성
    let user1 = create_user(db, "Alice", "alice@example.com", 28)
    let user2 = create_user(db, "Bob", "bob@example.com", 32)

    // User 조회
    let alice = find_user_by_id(db, user1.id)

    // User 업데이트
    let updated_user = update_user(db, user1.id, "Alice Updated", "alice.new@example.com")

    // Post 생성
    let post1 = create_post(db, user1.id, "First Post", "Hello, World!")
    let post2 = create_post(db, user1.id, "Second Post", "Learning FV 2.0")

    // Post 게시
    publish_post(db, post1.id)

    // Comment 추가
    let comment = add_comment(db, post1.id, user2.id, "Great post!")

    // 통계
    let total_posts = count_posts(db)

    // 트랜잭션 예제
    begin_transaction(db)

    let user3 = create_user(db, "Charlie", "charlie@example.com", 25)
    let user4 = create_user(db, "Diana", "diana@example.com", 27)

    commit_transaction(db)

    // 배치 처리
    let users = [user1, user2]
    batch_insert_users(db, users)

    // 페이지네이션
    find_users_paginated(db, 1, 10)

    // 필터링 및 정렬
    find_users_by_age(db, 20, 35)

    // JOIN 쿼리
    find_posts_with_user(db)
}
