// Comment 추가
fn add_comment(db: Database, post_id: i64, user_id: i64, text: string) Comment {
    // INSERT INTO comments (post_id, user_id, text, created_at) VALUES (?, ?, ?, ?)
    let comment = Comment {
        id: 1,
        post_id: post_id,
        user_id: user_id,
        text: text
    }
    return comment
}

// Post 통계 (COUNT)
fn count_posts(db: Database) i64 {
    // SELECT COUNT(*) FROM posts
    let count = 42
    return count
}

// 트랜잭션 시작
fn begin_transaction(db: Database) {
