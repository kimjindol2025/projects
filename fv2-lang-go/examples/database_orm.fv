// 배치 삽입
fn batch_insert_users(db: Database, users: [User]) {
    // INSERT INTO users (id, name, email, age) VALUES (?, ?, ?, ?), (?, ?, ?, ?)
    for i in 0..3 {
        let user = User {
            id: i,
            name: "User",
            email: "user@example.com",
            age: 25,
            created_at: "2026-03-19"
        }
    }
}

// 페이지네이션
fn find_users_paginated(db: Database, page: i64, limit: i64) {
    // SELECT * FROM users LIMIT ? OFFSET ?
    let offset = (page - 1) * limit
}

// 정렬 및 필터링
fn find_users_by_age(db: Database, min_age: i64, max_age: i64) {
