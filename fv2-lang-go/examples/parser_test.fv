// FV Parser 테스트 (V 언어)
// 8개 테스트 케이스로 완벽한 검증

// 테스트 1: 기본 함수 정의 파싱
fn test_parse_function_def() {
	// 토큰 생성 (간략 버전)
	// fn add(a: i32, b: i32) -> i32 { ... }
	mut tokens: []Token = [
		Token{type_val: 1, text: "fn", line: 1, column: 1},      // TknFn
		Token{type_val: 10, text: "add", line: 1, column: 4},    // TknIdentifier
		Token{type_val: 12, text: "(", line: 1, column: 7},      // TknLParen
		Token{type_val: 10, text: "a", line: 1, column: 8},      // TknIdentifier
		Token{type_val: 30, text: ":", line: 1, column: 9},      // TknColon
		Token{type_val: 10, text: "i32", line: 1, column: 10},   // TknIdentifier
		Token{type_val: 14, text: ",", line: 1, column: 13},     // TknComma
		Token{type_val: 10, text: "b", line: 1, column: 15},     // TknIdentifier
		Token{type_val: 30, text: ":", line: 1, column: 16},     // TknColon
		Token{type_val: 10, text: "i32", line: 1, column: 17},   // TknIdentifier
		Token{type_val: 13, text: ")", line: 1, column: 20},     // TknRParen
		Token{type_val: 31, text: "->", line: 1, column: 22},    // TknArrow
		Token{type_val: 10, text: "i32", line: 1, column: 25},   // TknIdentifier
		Token{type_val: 14, text: "{", line: 1, column: 28},     // TknLBrace
		Token{type_val: 99, text: "EOF", line: 1, column: 100},  // TknEOF
	]

	mut parser = new_parser(tokens)
	// if let Some(program) = parser.parse() {
	//	 assert program.definitions.len() >= 1
	// }
}

// 테스트 2: 구조체 정의 파싱
fn test_parse_struct_def() {
	// struct Point {
	//   x: f64
	//   y: f64
	// }
	mut tokens: []Token = [
		Token{type_val: 3, text: "struct", line: 1, column: 1},  // TknStruct
		Token{type_val: 10, text: "Point", line: 1, column: 8},  // TknIdentifier
		Token{type_val: 14, text: "{", line: 1, column: 13},     // TknLBrace
		Token{type_val: 10, text: "x", line: 2, column: 3},      // TknIdentifier
		Token{type_val: 30, text: ":", line: 2, column: 4},      // TknColon
		Token{type_val: 10, text: "f64", line: 2, column: 5},    // TknIdentifier
		Token{type_val: 10, text: "y", line: 3, column: 3},      // TknIdentifier
		Token{type_val: 30, text: ":", line: 3, column: 4},      // TknColon
		Token{type_val: 10, text: "f64", line: 3, column: 5},    // TknIdentifier
		Token{type_val: 15, text: "}", line: 4, column: 1},      // TknRBrace
		Token{type_val: 99, text: "EOF", line: 4, column: 100},  // TknEOF
	]

	mut parser = new_parser(tokens)
	// if let Some(program) = parser.parse() {
	//	 assert program.definitions.len() >= 1
	// }
}

// 테스트 3: let 바인딩 파싱
fn test_parse_let_statement() {
	// let x: i32 = 42
	mut tokens: []Token = [
		Token{type_val: 6, text: "let", line: 1, column: 1},     // TknLet
		Token{type_val: 10, text: "x", line: 1, column: 5},      // TknIdentifier
		Token{type_val: 30, text: ":", line: 1, column: 6},      // TknColon
		Token{type_val: 10, text: "i32", line: 1, column: 7},    // TknIdentifier
		Token{type_val: 32, text: "=", line: 1, column: 11},     // TknAssign
		Token{type_val: 20, text: "42", line: 1, column: 13},    // TknInt
		Token{type_val: 99, text: "EOF", line: 1, column: 100},  // TknEOF
	]

	mut parser = new_parser(tokens)
	// if let Some(program) = parser.parse() {
	//	 assert program.main_body.len() >= 1
	// }
}

// 테스트 4: if 문 파싱
fn test_parse_if_statement() {
	// if x > 0 {
	//   return x
	// } else {
	//   return 0
	// }
	mut tokens: []Token = [
		Token{type_val: 8, text: "if", line: 1, column: 1},      // TknIf
		Token{type_val: 10, text: "x", line: 1, column: 4},      // TknIdentifier
		Token{type_val: 41, text: ">", line: 1, column: 6},      // TknGT
		Token{type_val: 20, text: "0", line: 1, column: 8},      // TknInt
		Token{type_val: 14, text: "{", line: 1, column: 10},     // TknLBrace
		Token{type_val: 17, text: "return", line: 2, column: 3}, // TknReturn
		Token{type_val: 10, text: "x", line: 2, column: 10},     // TknIdentifier
		Token{type_val: 15, text: "}", line: 3, column: 1},      // TknRBrace
		Token{type_val: 18, text: "else", line: 3, column: 3},   // TknElse
		Token{type_val: 14, text: "{", line: 3, column: 8},      // TknLBrace
		Token{type_val: 17, text: "return", line: 4, column: 3}, // TknReturn
		Token{type_val: 20, text: "0", line: 4, column: 10},     // TknInt
		Token{type_val: 15, text: "}", line: 5, column: 1},      // TknRBrace
		Token{type_val: 99, text: "EOF", line: 5, column: 100},  // TknEOF
	]

	mut parser = new_parser(tokens)
	// if let Some(program) = parser.parse() {
	//	 assert program.main_body.len() >= 1
	// }
}

// 테스트 5: for 루프 파싱
fn test_parse_for_statement() {
	// for i in array {
	//   println(i)
	// }
	mut tokens: []Token = [
		Token{type_val: 9, text: "for", line: 1, column: 1},     // TknFor
		Token{type_val: 10, text: "i", line: 1, column: 5},      // TknIdentifier
		Token{type_val: 19, text: "in", line: 1, column: 7},     // TknIn
		Token{type_val: 10, text: "array", line: 1, column: 10}, // TknIdentifier
		Token{type_val: 14, text: "{", line: 1, column: 15},     // TknLBrace
		Token{type_val: 10, text: "println", line: 2, column: 3},// TknIdentifier
		Token{type_val: 12, text: "(", line: 2, column: 10},     // TknLParen
		Token{type_val: 10, text: "i", line: 2, column: 11},     // TknIdentifier
		Token{type_val: 13, text: ")", line: 2, column: 12},     // TknRParen
		Token{type_val: 15, text: "}", line: 3, column: 1},      // TknRBrace
		Token{type_val: 99, text: "EOF", line: 3, column: 100},  // TknEOF
	]

	mut parser = new_parser(tokens)
	// if let Some(program) = parser.parse() {
	//	 assert program.main_body.len() >= 1
	// }
}

// 테스트 6: enum 정의 파싱
fn test_parse_enum_def() {
	// enum Result {
	//   Ok(T)
	//   Err(E)
	// }
	mut tokens: []Token = [
		Token{type_val: 5, text: "enum", line: 1, column: 1},    // TknEnum
		Token{type_val: 10, text: "Result", line: 1, column: 6}, // TknIdentifier
		Token{type_val: 14, text: "{", line: 1, column: 12},     // TknLBrace
		Token{type_val: 10, text: "Ok", line: 2, column: 3},     // TknIdentifier
		Token{type_val: 12, text: "(", line: 2, column: 5},      // TknLParen
		Token{type_val: 10, text: "T", line: 2, column: 6},      // TknIdentifier
		Token{type_val: 13, text: ")", line: 2, column: 7},      // TknRParen
		Token{type_val: 10, text: "Err", line: 3, column: 3},    // TknIdentifier
		Token{type_val: 12, text: "(", line: 3, column: 6},      // TknLParen
		Token{type_val: 10, text: "E", line: 3, column: 7},      // TknIdentifier
		Token{type_val: 13, text: ")", line: 3, column: 8},      // TknRParen
		Token{type_val: 15, text: "}", line: 4, column: 1},      // TknRBrace
		Token{type_val: 99, text: "EOF", line: 4, column: 100},  // TknEOF
	]

	mut parser = new_parser(tokens)
	// if let Some(program) = parser.parse() {
	//	 assert program.definitions.len() >= 1
	// }
}

// 테스트 7: interface 정의 파싱
fn test_parse_interface_def() {
	// interface Drawable {
	//   draw() -> void
	// }
	mut tokens: []Token = [
		Token{type_val: 4, text: "interface", line: 1, column: 1}, // TknInterface
		Token{type_val: 10, text: "Drawable", line: 1, column: 11}, // TknIdentifier
		Token{type_val: 14, text: "{", line: 1, column: 19},     // TknLBrace
		Token{type_val: 10, text: "draw", line: 2, column: 3},   // TknIdentifier
		Token{type_val: 12, text: "(", line: 2, column: 7},      // TknLParen
		Token{type_val: 13, text: ")", line: 2, column: 8},      // TknRParen
		Token{type_val: 31, text: "->", line: 2, column: 10},    // TknArrow
		Token{type_val: 10, text: "void", line: 2, column: 12},  // TknIdentifier
		Token{type_val: 15, text: "}", line: 3, column: 1},      // TknRBrace
		Token{type_val: 99, text: "EOF", line: 3, column: 100},  // TknEOF
	]

	mut parser = new_parser(tokens)
	// if let Some(program) = parser.parse() {
	//	 assert program.definitions.len() >= 1
	// }
}

// 테스트 8: 복합 프로그램 파싱
fn test_parse_complex_program() {
	// fn main() {
	//   let x: i32 = 42
	//   if x > 0 {
	//     return x
	//   }
	// }
	mut tokens: []Token = [
		Token{type_val: 1, text: "fn", line: 1, column: 1},      // TknFn
		Token{type_val: 10, text: "main", line: 1, column: 4},   // TknIdentifier
		Token{type_val: 12, text: "(", line: 1, column: 8},      // TknLParen
		Token{type_val: 13, text: ")", line: 1, column: 9},      // TknRParen
		Token{type_val: 14, text: "{", line: 1, column: 11},     // TknLBrace
		Token{type_val: 6, text: "let", line: 2, column: 3},     // TknLet
		Token{type_val: 10, text: "x", line: 2, column: 7},      // TknIdentifier
		Token{type_val: 30, text: ":", line: 2, column: 8},      // TknColon
		Token{type_val: 10, text: "i32", line: 2, column: 9},    // TknIdentifier
		Token{type_val: 32, text: "=", line: 2, column: 13},     // TknAssign
		Token{type_val: 20, text: "42", line: 2, column: 15},    // TknInt
		Token{type_val: 8, text: "if", line: 3, column: 3},      // TknIf
		Token{type_val: 10, text: "x", line: 3, column: 6},      // TknIdentifier
		Token{type_val: 41, text: ">", line: 3, column: 8},      // TknGT
		Token{type_val: 20, text: "0", line: 3, column: 10},     // TknInt
		Token{type_val: 14, text: "{", line: 3, column: 12},     // TknLBrace
		Token{type_val: 17, text: "return", line: 4, column: 5}, // TknReturn
		Token{type_val: 10, text: "x", line: 4, column: 12},     // TknIdentifier
		Token{type_val: 15, text: "}", line: 5, column: 3},      // TknRBrace
		Token{type_val: 15, text: "}", line: 6, column: 1},      // TknRBrace
		Token{type_val: 99, text: "EOF", line: 6, column: 100},  // TknEOF
	]

	mut parser = new_parser(tokens)
	// if let Some(program) = parser.parse() {
	//	 assert program.definitions.len() >= 1
	//	 assert program.main_body.is_empty() == false
	// }
}
